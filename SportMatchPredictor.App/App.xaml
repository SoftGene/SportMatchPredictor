<Application x:Class="SportMatchPredictor.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- Material Design — правильные словари для v4.x -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <!-- ─── Цветовая палитра (зелёная) ─── -->
            <SolidColorBrush x:Key="PrimaryHueLightBrush"              Color="#B1D18A"/>
            <SolidColorBrush x:Key="PrimaryHueMidBrush"                Color="#4C662B"/>
            <SolidColorBrush x:Key="PrimaryHueDarkBrush"               Color="#394E1F"/>

            <SolidColorBrush x:Key="PrimaryHueLightForegroundBrush"    Color="#102000"/>
            <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="PrimaryHueDarkForegroundBrush"     Color="#FFFFFF"/>

            <!-- Secondary / accent не используется активно, задаём нейтральным -->
            <SolidColorBrush x:Key="SecondaryHueMidBrush"              Color="#DDE8CB"/>
            <SolidColorBrush x:Key="SecondaryHueMidForegroundBrush"    Color="#102000"/>

            <!-- ─── Поверхности и фон ─── -->
            <SolidColorBrush x:Key="MaterialDesignBackground"          Color="#F7F8F2"/>
            <SolidColorBrush x:Key="MaterialDesignPaper"               Color="#FFFFFF"/>
            <SolidColorBrush x:Key="MaterialDesignCardBackground"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="MaterialDesignDivider"             Color="#D9DFCF"/>
            <SolidColorBrush x:Key="MaterialDesignToolBarBackground"   Color="#EEF3E6"/>
            <SolidColorBrush x:Key="MaterialDesignBody"                Color="#1B1C18"/>
            <SolidColorBrush x:Key="MaterialDesignBodyLight"           Color="#5F6656"/>
            <SolidColorBrush x:Key="MaterialDesignCheckBoxOff"         Color="#6B7261"/>

            <!-- ─── Вспомогательные кисти ─── -->
            <SolidColorBrush x:Key="AppOutlineBrush"                   Color="#C5CCB8"/>
            <SolidColorBrush x:Key="SuccessBrush"                      Color="#66BB6A"/>
            <SolidColorBrush x:Key="WarnBrush"                         Color="#FFA726"/>
            <SolidColorBrush x:Key="DangerBrush"                       Color="#EF5350"/>

            <!-- ─── Стиль окна ─── -->
            <Style TargetType="Window">
                <Setter Property="Background"              Value="{DynamicResource MaterialDesignBackground}"/>
                <Setter Property="TextElement.Foreground"  Value="{DynamicResource MaterialDesignBody}"/>
                <Setter Property="FontFamily"              Value="{materialDesign:MaterialDesignFont}"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>