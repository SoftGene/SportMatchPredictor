<Application x:Class="SportMatchPredictor.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- Material Design — правильные словари для v4.x -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <!-- ─── Цветовая палитра (зелёная) ─── -->
            <SolidColorBrush x:Key="PrimaryHueLightBrush"              Color="#B1D18A"/>
            <SolidColorBrush x:Key="PrimaryHueMidBrush"                Color="#4C662B"/>
            <SolidColorBrush x:Key="PrimaryHueDarkBrush"               Color="#394E1F"/>

            <SolidColorBrush x:Key="PrimaryHueLightForegroundBrush"    Color="#102000"/>
            <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="PrimaryHueDarkForegroundBrush"     Color="#FFFFFF"/>

            <!-- Secondary / accent не используется активно, задаём нейтральным -->
            <SolidColorBrush x:Key="SecondaryHueMidBrush"              Color="#DDE8CB"/>
            <SolidColorBrush x:Key="SecondaryHueMidForegroundBrush"    Color="#102000"/>

            <!-- ─── Поверхности и фон ─── -->
            <SolidColorBrush x:Key="MaterialDesignBackground"          Color="#F7F8F2"/>
            <SolidColorBrush x:Key="MaterialDesignPaper"               Color="#FFFFFF"/>
            <SolidColorBrush x:Key="MaterialDesignCardBackground"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="MaterialDesignDivider"             Color="#D9DFCF"/>
            <SolidColorBrush x:Key="MaterialDesignToolBarBackground"   Color="#EEF3E6"/>
            <SolidColorBrush x:Key="MaterialDesignBody"                Color="#1B1C18"/>
            <SolidColorBrush x:Key="MaterialDesignBodyLight"           Color="#5F6656"/>
            <SolidColorBrush x:Key="MaterialDesignCheckBoxOff"         Color="#6B7261"/>

            <!-- ─── Вспомогательные кисти ─── -->
            <SolidColorBrush x:Key="AppOutlineBrush"                   Color="#C5CCB8"/>
            <SolidColorBrush x:Key="SuccessBrush"                      Color="#66BB6A"/>
            <SolidColorBrush x:Key="WarnBrush"                         Color="#FFA726"/>
            <SolidColorBrush x:Key="DangerBrush"                       Color="#EF5350"/>
            <SolidColorBrush x:Key="SurfaceTintBrush"                  Color="#F2F5EA"/>
            <SolidColorBrush x:Key="SuccessSurfaceBrush"               Color="#E8F4E5"/>
            <SolidColorBrush x:Key="WarnSurfaceBrush"                  Color="#FFF2E1"/>
            <SolidColorBrush x:Key="DangerSurfaceBrush"                Color="#FCE7E5"/>

            <!-- ─── Стиль окна ─── -->
            <Style TargetType="Window">
                <Setter Property="Background"              Value="{DynamicResource MaterialDesignBackground}"/>
                <Setter Property="TextElement.Foreground"  Value="{DynamicResource MaterialDesignBody}"/>
                <Setter Property="FontFamily"              Value="{materialDesign:MaterialDesignFont}"/>
            </Style>

            <Style x:Key="OptionCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Grid SnapsToDevicePixels="True"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="CheckBorder"
                                        Grid.Column="0"
                                        Width="20"
                                        Height="20"
                                        CornerRadius="6"
                                        Background="{DynamicResource MaterialDesignPaper}"
                                        BorderBrush="{DynamicResource AppOutlineBrush}"
                                        BorderThickness="1.5"
                                        VerticalAlignment="Center">
                                    <Path x:Name="CheckGlyph"
                                          Data="M2,5 L5.5,9 L12,1"
                                          Stroke="White"
                                          StrokeThickness="2.2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="11"
                                          Height="9"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Stretch="Uniform"
                                          Visibility="Collapsed"/>
                                </Border>

                                <ContentPresenter Grid.Column="2"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="CheckBorder" Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                    <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                    <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SelectionComboBoxStyle"
       TargetType="ComboBox"
       BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                <Setter Property="Height"                              Value="48"/>
                <Setter Property="MinHeight"                           Value="48"/>
                <Setter Property="Padding"                             Value="14,12,34,12"/>
                <Setter Property="Background"                          Value="{DynamicResource MaterialDesignPaper}"/>
                <Setter Property="BorderBrush"                         Value="{DynamicResource AppOutlineBrush}"/>
                <Setter Property="BorderThickness"                     Value="1.5"/>
                <Setter Property="Foreground"                          Value="{DynamicResource MaterialDesignBody}"/>
                <Setter Property="VerticalContentAlignment"            Value="Center"/>
                <Setter Property="materialDesign:HintAssist.IsFloating" Value="False"/>
                <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                        <Setter Property="BorderThickness" Value="1.5"/>
                    </Trigger>
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                        <Setter Property="BorderThickness" Value="1.5"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
