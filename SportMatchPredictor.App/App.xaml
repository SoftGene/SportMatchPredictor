<Application x:Class="SportMatchPredictor.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- Material Design theme dictionaries -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <!-- ─── Color palette (green) ─── -->
            <SolidColorBrush x:Key="PrimaryHueLightBrush"              Color="#B1D18A"/>
            <SolidColorBrush x:Key="PrimaryHueMidBrush"                Color="#4C662B"/>
            <SolidColorBrush x:Key="PrimaryHueDarkBrush"               Color="#394E1F"/>

            <SolidColorBrush x:Key="PrimaryHueLightForegroundBrush"    Color="#102000"/>
            <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="PrimaryHueDarkForegroundBrush"     Color="#FFFFFF"/>

            <!-- Secondary / accent is not actively used, set to neutral -->
            <SolidColorBrush x:Key="SecondaryHueMidBrush"              Color="#DDE8CB"/>
            <SolidColorBrush x:Key="SecondaryHueMidForegroundBrush"    Color="#102000"/>

            <!-- ─── Surfaces and background ─── -->
            <SolidColorBrush x:Key="MaterialDesignBackground"          Color="#F7F8F2"/>
            <SolidColorBrush x:Key="MaterialDesignPaper"               Color="#FFFFFF"/>
            <SolidColorBrush x:Key="MaterialDesignCardBackground"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="MaterialDesignDivider"             Color="#D9DFCF"/>
            <SolidColorBrush x:Key="MaterialDesignToolBarBackground"   Color="#EEF3E6"/>
            <SolidColorBrush x:Key="MaterialDesignBody"                Color="#1B1C18"/>
            <SolidColorBrush x:Key="MaterialDesignBodyLight"           Color="#5F6656"/>
            <SolidColorBrush x:Key="MaterialDesignCheckBoxOff"         Color="#6B7261"/>

            <!-- ─── Utility brushes ─── -->
            <SolidColorBrush x:Key="AppOutlineBrush"                   Color="#C5CCB8"/>
            <SolidColorBrush x:Key="SuccessBrush"                      Color="#66BB6A"/>
            <SolidColorBrush x:Key="WarnBrush"                         Color="#FFA726"/>
            <SolidColorBrush x:Key="DangerBrush"                       Color="#EF5350"/>
            <SolidColorBrush x:Key="SurfaceTintBrush"                  Color="#F2F5EA"/>
            <SolidColorBrush x:Key="SuccessSurfaceBrush"               Color="#E8F4E5"/>
            <SolidColorBrush x:Key="WarnSurfaceBrush"                  Color="#FFF2E1"/>
            <SolidColorBrush x:Key="DangerSurfaceBrush"                Color="#FCE7E5"/>
            <SolidColorBrush x:Key="SecondaryAccentBrush"              Color="#DDE8CB"/>
            <SolidColorBrush x:Key="CardSurfaceBrush"                  Color="#FFFFFF"/>

            <!-- ─── Category tints (Attack / Defense / Form / Momentum) ─── -->
            <SolidColorBrush x:Key="CatAttackBg"    Color="#E8F1E6"/>
            <SolidColorBrush x:Key="CatAttackFg"    Color="#2E6B3A"/>
            <SolidColorBrush x:Key="CatDefenseBg"   Color="#FFEEE9"/>
            <SolidColorBrush x:Key="CatDefenseFg"   Color="#B75B4A"/>
            <SolidColorBrush x:Key="CatFormBg"      Color="#FFF4E1"/>
            <SolidColorBrush x:Key="CatFormFg"      Color="#A57028"/>
            <SolidColorBrush x:Key="CatMomentumBg"  Color="#E4EDFF"/>
            <SolidColorBrush x:Key="CatMomentumFg" Color="#3A5A9C"/>

            <!-- ─── Diverging-bar tracks and fills ─── -->
            <SolidColorBrush x:Key="BarTrackBrush"  Color="#F3F3EE"/>
            <SolidColorBrush x:Key="BarAxisBrush"   Color="#C9CEC2"/>

            <LinearGradientBrush x:Key="HomeBarBrush" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#C9E2CC" Offset="0"/>
                <GradientStop Color="#2E6B3A" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AwayBarBrush" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#B75B4A" Offset="0"/>
                <GradientStop Color="#D79083" Offset="1"/>
            </LinearGradientBrush>

            <SolidColorBrush x:Key="HomeValueBrush"  Color="#2E6B3A"/>
            <SolidColorBrush x:Key="AwayValueBrush"  Color="#B75B4A"/>

            <!-- Delta pill brushes -->
            <SolidColorBrush x:Key="DeltaPosBg" Color="#E8F1E6"/>
            <SolidColorBrush x:Key="DeltaPosFg" Color="#2E6B3A"/>
            <SolidColorBrush x:Key="DeltaNegBg" Color="#FCE6E1"/>
            <SolidColorBrush x:Key="DeltaNegFg" Color="#C94A3E"/>
            <SolidColorBrush x:Key="DeltaNeuBg" Color="#F3EBDD"/>
            <SolidColorBrush x:Key="DeltaNeuFg" Color="#B8894A"/>

            <!-- Metric row hover -->
            <SolidColorBrush x:Key="MetricRowHoverBrush" Color="#F5F7F2"/>

            <Style TargetType="materialDesign:Card">
                <Setter Property="Background" Value="{DynamicResource CardSurfaceBrush}"/>
            </Style>

            <!-- ── Green TabItem (Computed Features / About Model) ── -->
            <Style x:Key="GreenTabItemStyle" TargetType="TabItem">
                <Setter Property="FontSize"    Value="13"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="Background"  Value="Transparent"/>
                <Setter Property="Padding"     Value="16,14"/>
                <Setter Property="Cursor"      Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Grid>
                                <!-- Base (inactive) label -->
                                <ContentPresenter x:Name="BaseLabel"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True"
                                                  TextElement.Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                <!-- Hover / selected label (fades in over the base) -->
                                <ContentPresenter x:Name="AccentLabel"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True"
                                                  Opacity="0"
                                                  TextElement.Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                <!-- Accent underline -->
                                <Border x:Name="Accent"
                                        VerticalAlignment="Bottom"
                                        Height="2"
                                        Background="{DynamicResource PrimaryHueMidBrush}"
                                        Opacity="0"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="AccentLabel"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.22"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="AccentLabel"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.26"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="AccentLabel" Property="Opacity" Value="1"/>
                                    <Setter TargetName="Accent"      Property="Opacity" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Animated hover for metric rows (Computed Features) ── -->
            <Style x:Key="MetricRowHoverStyle" TargetType="Border">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="Transparent"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#14808080" Duration="0:0:0.18"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#00808080" Duration="0:0:0.22"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <!-- ── Smooth fade-in + slide-up for TabItem content ── -->
            <Style x:Key="TabContentFadeInStyle" TargetType="ScrollViewer">
                <Setter Property="Opacity" Value="0"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="10"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.28"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 From="10" To="0" Duration="0:0:0.28">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <!-- ── Animated lift for About Model tiles ── -->
            <Style x:Key="InfoTileStyle" TargetType="materialDesign:Card">
                <Setter Property="Background"          Value="{DynamicResource CardSurfaceBrush}"/>
                <Setter Property="BorderBrush"         Value="{DynamicResource MaterialDesignDivider}"/>
                <Setter Property="BorderThickness"     Value="1"/>
                <Setter Property="UniformCornerRadius" Value="12"/>
                <Setter Property="Padding"             Value="18"/>
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp1"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="Cursor"              Value="Hand"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="0"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="0" ShadowDepth="0" Opacity="0"
                                          Color="#2E6B3A"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="-3" Duration="0:0:0.20"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                 To="18" Duration="0:0:0.20"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                 To="0.18" Duration="0:0:0.20"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="0" Duration="0:0:0.24"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                 To="0" Duration="0:0:0.24"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                 To="0" Duration="0:0:0.24"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <!-- ─── Window style ─── -->
            <Style TargetType="Window">
                <Setter Property="Background"             Value="{DynamicResource MaterialDesignBackground}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                <Setter Property="FontFamily"             Value="{materialDesign:MaterialDesignFont}"/>
                <Setter Property="UseLayoutRounding"      Value="True"/>
                <Setter Property="SnapsToDevicePixels"    Value="True"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
                <Setter Property="TextOptions.TextRenderingMode"  Value="ClearType"/>
                <Setter Property="RenderOptions.ClearTypeHint"    Value="Enabled"/>
            </Style>

            <Style x:Key="OptionCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="Foreground"                Value="{DynamicResource MaterialDesignBody}"/>
                <Setter Property="FontSize"                  Value="12.5"/>
                <Setter Property="VerticalContentAlignment"  Value="Center"/>
                <Setter Property="Cursor"                    Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Grid SnapsToDevicePixels="True"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="CheckBorder"
                                        Grid.Column="0"
                                        Width="20"
                                        Height="20"
                                        CornerRadius="6"
                                        Background="{DynamicResource MaterialDesignPaper}"
                                        BorderBrush="{DynamicResource AppOutlineBrush}"
                                        BorderThickness="1.5"
                                        VerticalAlignment="Center">
                                    <Path x:Name="CheckGlyph"
                                          Data="M2,5 L5.5,9 L12,1"
                                          Stroke="White"
                                          StrokeThickness="2.2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="11"
                                          Height="9"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Stretch="Uniform"
                                          Visibility="Collapsed"/>
                                </Border>

                                <ContentPresenter Grid.Column="2"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="CheckBorder" Property="Background"   Value="{DynamicResource PrimaryHueMidBrush}"/>
                                    <Setter TargetName="CheckBorder" Property="BorderBrush"  Value="{DynamicResource PrimaryHueMidBrush}"/>
                                    <Setter TargetName="CheckGlyph"  Property="Visibility"   Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CheckBorder" Property="BorderBrush"  Value="{DynamicResource PrimaryHueMidBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SelectionComboBoxStyle"
                   TargetType="ComboBox"
                   BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                <Setter Property="Height"                               Value="48"/>
                <Setter Property="MinHeight"                            Value="48"/>
                <Setter Property="Padding"                              Value="14,12,34,12"/>
                <Setter Property="Background"                           Value="{DynamicResource MaterialDesignPaper}"/>
                <Setter Property="BorderBrush"                          Value="{DynamicResource AppOutlineBrush}"/>
                <Setter Property="BorderThickness"                      Value="1.5"/>
                <Setter Property="Foreground"                           Value="{DynamicResource MaterialDesignBody}"/>
                <Setter Property="VerticalContentAlignment"             Value="Center"/>
                <Setter Property="materialDesign:HintAssist.IsFloating" Value="False"/>
                <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush"     Value="{DynamicResource PrimaryHueMidBrush}"/>
                        <Setter Property="BorderThickness"  Value="1.5"/>
                    </Trigger>
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter Property="BorderBrush"     Value="{DynamicResource PrimaryHueMidBrush}"/>
                        <Setter Property="BorderThickness"  Value="1.5"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="ToolTip">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToolTip">
                            <Border Background="{DynamicResource MaterialDesignPaper}"
                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,6">
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="12"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>