<Window x:Class="SportMatchPredictor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="SportMatchPredictor"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontSize="14"
        Background="{DynamicResource MaterialDesignBackground}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════
             HEADER BAR
        ════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryHueDarkBrush}">
            <Grid Margin="28,0,24,0">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <materialDesign:PackIcon Kind="TuneVariant"
                                             Width="26" Height="26"
                                             Foreground="White"
                                             VerticalAlignment="Center"
                                             Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SportMatchPredictor"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Probabilistic match outcome prediction  ·  OVA + FastTree  ·  time-aware features"
                                   Foreground="White"
                                   Opacity="0.65"
                                   FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Background="#26FFFFFF"
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Memory"
                                                 Width="15" Height="15"
                                                 Foreground="White"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,7,0"/>
                        <TextBlock Text="model.zip  ·  .NET 8  ·  ML.NET"
                                   Foreground="White"
                                   Opacity="0.9"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════
             MAIN CONTENT
        ════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="20,16,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────
                 LEFT CARD — Match Configuration
            ──────────────────────────────────────── -->
            <materialDesign:Card Grid.Column="0"
                                 materialDesign:ElevationAssist.Elevation="Dp3"
                                 UniformCornerRadius="12"
                                 Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Card header band -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource PrimaryHueMidBrush}"
                            CornerRadius="12,12,0,0"
                            Padding="22,16">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Soccer"
                                                     Width="22" Height="22"
                                                     Foreground="White"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,10,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Match Configuration"
                                           Foreground="White"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Select teams and season"
                                           Foreground="White"
                                           Opacity="0.7"
                                           FontSize="11"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Form -->
                    <StackPanel Grid.Row="1" Margin="22,20,22,4">

                        <TextBlock Text="SEASON"
                                   FontSize="10" FontWeight="Medium"
                                   Opacity="0.5" Margin="0,0,0,6"/>
                        <ComboBox x:Name="SeasonCombo"
                                  materialDesign:HintAssist.Hint="Select season"
                                  Height="44"
                                  Margin="0,0,0,20"/>

                        <TextBlock Text="HOME TEAM"
                                   FontSize="10" FontWeight="Medium"
                                   Opacity="0.5" Margin="0,0,0,6"/>
                        <ComboBox x:Name="HomeTeamCombo"
                                  materialDesign:HintAssist.Hint="Choose home team"
                                  IsEditable="True"
                                  Height="44"
                                  Margin="0,0,0,0"/>

                        <!-- VS divider -->
                        <Grid Margin="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Height="1"
                                       VerticalAlignment="Center"
                                       Fill="{DynamicResource MaterialDesignDivider}"/>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource PrimaryHueMidBrush}"
                                    CornerRadius="20"
                                    Width="38" Height="38"
                                    Margin="10,0">
                                <TextBlock Text="VS"
                                           Foreground="White"
                                           FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Rectangle Grid.Column="2" Height="1"
                                       VerticalAlignment="Center"
                                       Fill="{DynamicResource MaterialDesignDivider}"/>
                        </Grid>

                        <TextBlock Text="AWAY TEAM"
                                   FontSize="10" FontWeight="Medium"
                                   Opacity="0.5" Margin="0,0,0,6"/>
                        <ComboBox x:Name="AwayTeamCombo"
                                  materialDesign:HintAssist.Hint="Choose away team"
                                  IsEditable="True"
                                  Height="44"
                                  Margin="0,0,0,24"/>

                        <!-- Predict — primary button -->
                        <Button x:Name="PredictBtn"
                                Content="PREDICT MATCH"
                                Click="PredictBtn_Click"
                                Height="50"
                                FontSize="14"
                                FontWeight="Bold"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                materialDesign:ElevationAssist.Elevation="Dp4"
                                Margin="0,0,0,10"/>

                        <!-- Clear — secondary button -->
                        <Button x:Name="ClearBtn"
                                Content="Clear Selection"
                                Click="ClearBtn_Click"
                                Height="40"
                                FontSize="13"
                                Background="Transparent"
                                BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                BorderThickness="1.5"
                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                materialDesign:ElevationAssist.Elevation="Dp0"/>

                    </StackPanel>

                    <!-- Options footer -->
                    <Border Grid.Row="2"
                            CornerRadius="0,0,12,12"
                            Background="{DynamicResource MaterialDesignToolBarBackground}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="0,1,0,0"
                            Padding="22,14">
                        <StackPanel>
                            <TextBlock Text="OPTIONS"
                                       FontSize="10" FontWeight="Medium"
                                       Opacity="0.45" Margin="0,0,0,10"/>
                            <CheckBox x:Name="IncludeFeatureSummary"
                                      Content="Show feature summary after prediction"
                                      IsChecked="True"
                                      FontSize="12"
                                      Margin="0,0,0,6"/>
                            <CheckBox x:Name="UseTimeAwareFeatures"
                                      Content="Use time-aware feature computation"
                                      IsChecked="True"
                                      FontSize="12"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </materialDesign:Card>

            <!-- ─────────────────────────────────────
                 RIGHT CARD — Prediction Result
            ──────────────────────────────────────── -->
            <materialDesign:Card Grid.Column="1"
                                 materialDesign:ElevationAssist.Elevation="Dp3"
                                 UniformCornerRadius="12"
                                 Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top bar -->
                    <Border Grid.Row="0"
                            Padding="26,16"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="PollBox"
                                                         Width="20" Height="20"
                                                         VerticalAlignment="Center"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                         Margin="0,0,10,0"/>
                                <TextBlock Text="Prediction Result"
                                           FontSize="15" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="PredictedDetailsText"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Opacity="0.55"
                                       FontSize="12"/>
                        </Grid>
                    </Border>

                    <!-- Hero outcome block -->
                    <Border Grid.Row="1"
                            Margin="26,18,26,0"
                            Padding="22,18"
                            CornerRadius="10"
                            Background="{DynamicResource MaterialDesignToolBarBackground}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="PREDICTED OUTCOME"
                                           FontSize="10" FontWeight="Medium"
                                           Opacity="0.45" Margin="0,0,0,5"/>
                                <TextBlock x:Name="PredictedLabelText"
                                           Text="—"
                                           FontSize="38"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Background="{DynamicResource PrimaryHueMidBrush}"
                                    CornerRadius="10"
                                    Padding="20,12"
                                    Margin="16,0,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="CONFIDENCE"
                                               Foreground="White"
                                               Opacity="0.75"
                                               FontSize="10" FontWeight="Medium"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,3"/>
                                    <TextBlock x:Name="ConfidenceText"
                                               Foreground="White"
                                               FontSize="26"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Probabilities label -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="26,18,26,0">
                        <TextBlock Text="OUTCOME PROBABILITIES"
                                   FontSize="10" FontWeight="Medium"
                                   Opacity="0.45" VerticalAlignment="Center"/>
                        <Rectangle Width="1" Height="12"
                                   Fill="{DynamicResource MaterialDesignDivider}"
                                   Margin="12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="softmax · last 5 matches per team"
                                   FontSize="11" Opacity="0.4"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Probability bars -->
                    <StackPanel Grid.Row="3" Margin="26,14,26,0">

                        <!-- Away win -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="58"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                <Border Width="10" Height="10" CornerRadius="5"
                                        Background="#EF5350" Margin="0,0,9,0"/>
                                <TextBlock Text="Away Win" VerticalAlignment="Center"
                                           FontSize="13" FontWeight="Medium"/>
                            </StackPanel>
                            <ProgressBar x:Name="AwayBar"
                                         Grid.Column="1" Height="12"
                                         Minimum="0" Maximum="1"
                                         Foreground="#EF5350"
                                         VerticalAlignment="Center"/>
                            <TextBlock x:Name="AwayPct"
                                       Grid.Column="2"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="#EF5350"/>
                        </Grid>

                        <!-- Draw -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="58"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                <Border Width="10" Height="10" CornerRadius="5"
                                        Background="#FFA726" Margin="0,0,9,0"/>
                                <TextBlock Text="Draw" VerticalAlignment="Center"
                                           FontSize="13" FontWeight="Medium"/>
                            </StackPanel>
                            <ProgressBar x:Name="DrawBar"
                                         Grid.Column="1" Height="12"
                                         Minimum="0" Maximum="1"
                                         Foreground="#FFA726"
                                         VerticalAlignment="Center"/>
                            <TextBlock x:Name="DrawPct"
                                       Grid.Column="2"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="#FFA726"/>
                        </Grid>

                        <!-- Home win -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="58"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                <Border Width="10" Height="10" CornerRadius="5"
                                        Background="#66BB6A" Margin="0,0,9,0"/>
                                <TextBlock Text="Home Win" VerticalAlignment="Center"
                                           FontSize="13" FontWeight="Medium"/>
                            </StackPanel>
                            <ProgressBar x:Name="HomeBar"
                                         Grid.Column="1" Height="12"
                                         Minimum="0" Maximum="1"
                                         Foreground="#66BB6A"
                                         VerticalAlignment="Center"/>
                            <TextBlock x:Name="HomePct"
                                       Grid.Column="2"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="#66BB6A"/>
                        </Grid>

                    </StackPanel>

                    <!-- Features debug expander -->
                    <ScrollViewer Grid.Row="4"
                                  Margin="26,14,26,20"
                                  VerticalScrollBarVisibility="Auto">
                        <Expander Header="Computed Features (debug)"
                                  IsExpanded="True"
                                  materialDesign:ExpanderAssist.HorizontalHeaderPadding="0,6,0,6">
                            <Border Margin="0,8,0,0"
                                    Padding="14"
                                    CornerRadius="8"
                                    Background="{DynamicResource MaterialDesignToolBarBackground}">
                                <TextBox x:Name="FeaturesDebug"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Opacity="0.82"
                                         VerticalScrollBarVisibility="Disabled"/>
                            </Border>
                        </Expander>
                    </ScrollViewer>

                </Grid>
            </materialDesign:Card>

        </Grid>

        <!-- ═══════════════════════════════════════════
             STATUS BAR
        ════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,1,0,0">
            <Grid Margin="22,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center"
                                             Opacity="0.45"
                                             Margin="0,0,7,0"/>
                    <TextBlock x:Name="StatusText"
                               FontSize="12" Opacity="0.6"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="SportMatchPredictor  ·  .NET 8  ·  ML.NET  ·  OVA + FastTree"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Opacity="0.35"/>
            </Grid>
        </Border>

    </Grid>
</Window>