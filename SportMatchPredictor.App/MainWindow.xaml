<Window x:Class="SportMatchPredictor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:SportMatchPredictor.App.Converters"
        Title="SportMatchPredictor"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontSize="14"
        Background="{DynamicResource MaterialDesignBackground}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <converters:PathToImageSourceConverter x:Key="PathToImageSourceConverter"/>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
        <converters:LessThanZeroConverter x:Key="LessThanZeroConverter"/>
        <DataTemplate x:Key="TeamItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Grid Width="24" Height="24" Margin="0,0,8,0">
                    <Border CornerRadius="12" Background="{DynamicResource PrimaryHueLightBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LogoPath}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Initial}"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryHueDarkBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Image RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Source"
                                        Value="{Binding LogoPath, Converter={StaticResource PathToImageSourceConverter}}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LogoPath}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Grid>
                <TextBlock Text="{Binding TeamLongName}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource MaterialDesignBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════
             HEADER BAR
        ════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryHueDarkBrush}">
            <Grid Margin="28,0,24,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <materialDesign:PackIcon Kind="TuneVariant"
                                             Width="26" Height="26"
                                             Foreground="White"
                                             VerticalAlignment="Center"
                                             Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SportMatchPredictor"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Probabilistic match outcome prediction  ·  OVA + FastTree  ·  time-aware features"
                                   Foreground="White"
                                   Opacity="0.65"
                                   FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Background="#26FFFFFF"
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Memory"
                                                 Width="15" Height="15"
                                                 Foreground="White"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,7,0"/>
                        <TextBlock Text="model.zip"
                                   Foreground="White"
                                   Opacity="0.9"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button x:Name="ThemeToggleBtn"
                        Click="ThemeToggleBtn_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="38"
                        Height="38"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="#40FFFFFF"
                        BorderThickness="0"
                        materialDesign:ButtonAssist.CornerRadius="19"
                        materialDesign:ElevationAssist.Elevation="Dp0"
                        ToolTip="Toggle dark/light theme"
                        Margin="0,0,110,0">
                    <materialDesign:PackIcon x:Name="ThemeIcon"
                                             Kind="WeatherNight"
                                             Width="20" Height="20"
                                             Foreground="White"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════
             MAIN CONTENT
        ════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="20,16,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────
                 LEFT CARD — Match Configuration
            ──────────────────────────────────────── -->
            <materialDesign:Card Grid.Column="0"
                                 materialDesign:ElevationAssist.Elevation="Dp3"
                                 UniformCornerRadius="12"
                                 Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Card header band -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource PrimaryHueMidBrush}"
                            CornerRadius="12,12,0,0"
                            Padding="22,16">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Soccer"
                                                     Width="22" Height="22"
                                                     Foreground="White"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,10,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Match Configuration"
                                           Foreground="White"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Select teams and season"
                                           Foreground="White"
                                           Opacity="0.7"
                                           FontSize="11"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Form -->
                    <StackPanel Grid.Row="1" Margin="22,20,22,4">

                        <TextBlock Text="SEASON"
                                   FontSize="10" FontWeight="Medium"
                                   Opacity="0.5" Margin="0,0,0,6"/>
                        <ComboBox x:Name="SeasonCombo"
                                  Style="{StaticResource SelectionComboBoxStyle}"
                                  materialDesign:HintAssist.Hint="Select season"
                                  Margin="0,0,0,20"
                                  SelectionChanged="SeasonCombo_SelectionChanged"/>

                        <TextBlock Text="HOME TEAM"
                                   FontSize="10" FontWeight="Medium"
                                   Opacity="0.5" Margin="0,0,0,6"/>
                        <Grid>
                            <ComboBox x:Name="HomeTeamCombo"
                                      IsEditable="True"
                                      TextSearch.TextPath="TeamLongName"
                                      ItemTemplate="{StaticResource TeamItemTemplate}"
                                      materialDesign:HintAssist.Hint="Select home team"
                                      Margin="0,0,0,0">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox" BasedOn="{StaticResource SelectionComboBoxStyle}">
                                        <Setter Property="Padding" Value="32,8,8,8"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem.LogoPath, RelativeSource={RelativeSource Self}}"
                                                         Value="{x:Null}">
                                                <Setter Property="Padding" Value="8,8,8,8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>
                            <Image Width="24" Height="24"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"
                                   Margin="6,0,0,0"
                                   IsHitTestVisible="False"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Source"
                                                Value="{Binding SelectedItem.LogoPath, ElementName=HomeTeamCombo, Converter={StaticResource PathToImageSourceConverter}}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem.LogoPath, ElementName=HomeTeamCombo}"
                                                         Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>

                        <!-- VS divider -->
                        <Grid Margin="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Height="1"
                                       VerticalAlignment="Center"
                                       Fill="{DynamicResource MaterialDesignDivider}"/>
                            <Button Grid.Column="1"
                                    x:Name="SwapBtn"
                                    Click="SwapBtn_Click"
                                    Width="38"
                                    Height="38"
                                    Margin="10,0"
                                    Background="{DynamicResource PrimaryHueMidBrush}"
                                    BorderThickness="0"
                                    Padding="0"
                                    materialDesign:ButtonAssist.CornerRadius="20"
                                    materialDesign:ElevationAssist.Elevation="Dp2"
                                    ToolTip="Swap teams">
                                <materialDesign:PackIcon Kind="SwapHorizontal"
                                                         Width="20" Height="20"
                                                         Foreground="White"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                            </Button>
                            <Rectangle Grid.Column="2" Height="1"
                                       VerticalAlignment="Center"
                                       Fill="{DynamicResource MaterialDesignDivider}"/>
                        </Grid>

                        <TextBlock Text="AWAY TEAM"
                                   FontSize="10" FontWeight="Medium"
                                   Opacity="0.5" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,24">
                            <ComboBox x:Name="AwayTeamCombo"
                                      IsEditable="True"
                                      TextSearch.TextPath="TeamLongName"
                                      ItemTemplate="{StaticResource TeamItemTemplate}"
                                      materialDesign:HintAssist.Hint="Select away team">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox" BasedOn="{StaticResource SelectionComboBoxStyle}">
                                        <Setter Property="Padding" Value="32,8,8,8"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem.LogoPath, RelativeSource={RelativeSource Self}}"
                                                         Value="{x:Null}">
                                                <Setter Property="Padding" Value="8,8,8,8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>
                            <Image Width="24" Height="24"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"
                                   Margin="6,0,0,0"
                                   IsHitTestVisible="False"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Source"
                                                Value="{Binding SelectedItem.LogoPath, ElementName=AwayTeamCombo, Converter={StaticResource PathToImageSourceConverter}}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem.LogoPath, ElementName=AwayTeamCombo}"
                                                         Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>

                        <!-- Predict — primary button -->
                        <Button x:Name="PredictBtn"
                                Content="PREDICT MATCH"
                                Click="PredictBtn_Click"
                                IsEnabled="False"
                                Height="50"
                                FontSize="14"
                                FontWeight="Bold"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                materialDesign:ElevationAssist.Elevation="Dp4"
                                Margin="0,0,0,10"/>

                        <!-- Clear — secondary button -->
                        <Button x:Name="ClearBtn"
                                Content="Clear Selection"
                                Click="ClearBtn_Click"
                                Height="40"
                                FontSize="13"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                Cursor="Hand"
                                materialDesign:ButtonAssist.CornerRadius="8"/>

                        <!-- Recent Predictions History -->
                        <TextBlock Text="RECENT PREDICTIONS"
                                   FontSize="10" FontWeight="Medium"
                                   Opacity="0.5" Margin="0,16,0,6"/>
                        <ListBox x:Name="HistoryList"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="11"
                                 Padding="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <!-- Branding footer -->
                    <Border Grid.Row="2"
                            CornerRadius="0,0,12,12"
                            Background="{DynamicResource MaterialDesignToolBarBackground}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="0,1,0,0"
                            Padding="22,14">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Soccer"
                                                     Width="20" Height="20"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,12,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Sport Match Predictor"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                <TextBlock Text="v1.0  ·  Diploma project"
                                           FontSize="11" Opacity="0.5" Margin="0,2,0,0"/>
                                <TextBlock Text="ML.NET  ·  .NET 8  ·  OVA + FastTree"
                                           FontSize="11" Opacity="0.5" Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </Grid>
            </materialDesign:Card>

            <!-- ─────────────────────────────────────
                 RIGHT CARD — Prediction Result
            ──────────────────────────────────────── -->
            <materialDesign:Card Grid.Column="1"
                                 materialDesign:ElevationAssist.Elevation="Dp3"
                                 UniformCornerRadius="12"
                                 Margin="10,0,0,0">
                <ScrollViewer x:Name="ResultScrollViewer"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid MinHeight="640">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Top bar -->
                        <Border x:Name="ResultHeader" Grid.Row="0"
                                Padding="26,16"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="PollBox"
                                                             Width="20" Height="20"
                                                             VerticalAlignment="Center"
                                                             Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                             Margin="0,0,10,0"/>
                                    <TextBlock Text="Prediction Result"
                                               FontSize="15" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="PredictedDetailsText"
                                           Margin="30,6,0,0"
                                           Opacity="0.58"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Hero outcome block -->
                        <Border x:Name="HeroBlock" Grid.Row="1"
                                Margin="26,18,26,0"
                                Padding="24,22"
                                CornerRadius="14"
                                Background="{DynamicResource SurfaceTintBrush}"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="190"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            VerticalAlignment="Center"
                                            Margin="0,0,22,0">
                                    <TextBlock Text="Predicted outcome"
                                               FontSize="12"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,8" VerticalAlignment="Center">
                                        <Image x:Name="HomeLogo"
                                               Width="32" Height="32"
                                               Visibility="Collapsed"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <Image x:Name="AwayLogo"
                                               Width="32" Height="32"
                                               Visibility="Collapsed"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock x:Name="PredictedLabelText"
                                                   Text="—"
                                                   FontSize="34"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Image x:Name="AwayLogoRight"
                                               Width="32" Height="32"
                                               Visibility="Collapsed"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </StackPanel>
                                    <TextBlock Text="Based on recent form and engineered match features."
                                               FontSize="12"
                                               Opacity="0.6"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource PrimaryHueDarkBrush}"
                                        CornerRadius="12"
                                        Padding="18,16">
                                    <StackPanel>
                                        <TextBlock Text="CONFIDENCE"
                                                   Foreground="White"
                                                   Opacity="0.68"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="ConfidenceText"
                                                   Foreground="White"
                                                   FontSize="32"
                                                   FontWeight="Bold"
                                                   Margin="0,6,0,4"/>
                                        <TextBlock Text="Highest class probability"
                                                   Foreground="White"
                                                   Opacity="0.68"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Probability panel -->
                        <Border x:Name="ProbabilityBlock" Grid.Row="2"
                                Margin="26,18,26,0"
                                Padding="20"
                                CornerRadius="12"
                                Background="{DynamicResource MaterialDesignPaper}"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="OUTCOME PROBABILITIES"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.45"
                                               VerticalAlignment="Center"/>
                                    <Rectangle Width="1"
                                               Height="12"
                                               Fill="{DynamicResource MaterialDesignDivider}"
                                               Margin="12,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Softmax distribution"
                                               FontSize="11"
                                               Opacity="0.45"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Away probability -->
                                <Border x:Name="AwayBorder"
                                        Margin="0,16,0,0"
                                        Padding="14,12"
                                        CornerRadius="10"
                                        Background="{DynamicResource DangerSurfaceBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="72"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Width="12"
                                                    Height="12"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource DangerBrush}"
                                                    Margin="0,0,10,0"/>
                                            <TextBlock Text="Away Win"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <ProgressBar x:Name="AwayBar"
                                                     Grid.Column="1"
                                                     Height="10"
                                                     Minimum="0"
                                                     Maximum="1"
                                                     Background="#33EF5350"
                                                     Foreground="{DynamicResource DangerBrush}"
                                                     VerticalAlignment="Center"/>
                                        <TextBlock x:Name="AwayPct"
                                                   Grid.Column="2"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource DangerBrush}"/>
                                    </Grid>
                                </Border>

                                <!-- Draw probability -->
                                <Border x:Name="DrawBorder"
                                        Margin="0,10,0,0"
                                        Padding="14,12"
                                        CornerRadius="10"
                                        Background="{DynamicResource WarnSurfaceBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="72"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Width="12"
                                                    Height="12"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource WarnBrush}"
                                                    Margin="0,0,10,0"/>
                                            <TextBlock Text="Draw"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <ProgressBar x:Name="DrawBar"
                                                     Grid.Column="1"
                                                     Height="10"
                                                     Minimum="0"
                                                     Maximum="1"
                                                     Background="#33FFA726"
                                                     Foreground="{DynamicResource WarnBrush}"
                                                     VerticalAlignment="Center"/>
                                        <TextBlock x:Name="DrawPct"
                                                   Grid.Column="2"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource WarnBrush}"/>
                                    </Grid>
                                </Border>

                                <!-- Home probability -->
                                <Border x:Name="HomeBorder"
                                        Margin="0,10,0,0"
                                        Padding="14,12"
                                        CornerRadius="10"
                                        Background="{DynamicResource SuccessSurfaceBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="72"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Width="12"
                                                    Height="12"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource SuccessBrush}"
                                                    Margin="0,0,10,0"/>
                                            <TextBlock Text="Home Win"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <ProgressBar x:Name="HomeBar"
                                                     Grid.Column="1"
                                                     Height="10"
                                                     Minimum="0"
                                                     Maximum="1"
                                                     Background="#3366BB6A"
                                                     Foreground="{DynamicResource SuccessBrush}"
                                                     VerticalAlignment="Center"/>
                                        <TextBlock x:Name="HomePct"
                                                   Grid.Column="2"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource SuccessBrush}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Features and Model Info Tabs -->
                        <Border x:Name="TabBlock" Grid.Row="3"
                                Margin="26,16,26,20"
                                CornerRadius="12"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="1"
                                Background="{DynamicResource MaterialDesignPaper}">
                            <TabControl Style="{StaticResource MaterialDesignTabControl}"
                                        materialDesign:ColorZoneAssist.Mode="PrimaryMid"
                                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                                        ClipToBounds="True">

                                <!-- ── Tab 1: Computed Features ── -->
                                <TabItem Header="Computed Features">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Feature Summary"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Margin="0,0,0,2"/>
                                            <TextBlock Text="Generated statistics used by the model"
                                                       FontSize="11" Opacity="0.55"
                                                       Margin="0,0,0,10"/>
                                            <DataGrid x:Name="FeaturesGrid"
                                                      Style="{StaticResource MaterialDesignDataGrid}"
                                                      AutoGenerateColumns="False"
                                                      IsReadOnly="True"
                                                      HeadersVisibility="Column"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      CanUserResizeColumns="False"
                                                      CanUserReorderColumns="False"
                                                      AlternationCount="0"
                                                      GridLinesVisibility="Horizontal"
                                                      SelectionMode="Single"
                                                      SelectionUnit="FullRow"
                                                      HorizontalGridLinesBrush="{DynamicResource MaterialDesignDivider}"
                                                      HorizontalScrollBarVisibility="Disabled">
                                                <DataGrid.RowStyle>
                                                    <Style TargetType="DataGridRow">
                                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                                    </Style>
                                                </DataGrid.RowStyle>
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Metric"
                                                                        Binding="{Binding Metric}"
                                                                        FontWeight="Medium"
                                                                        Width="*"/>
                                                    <DataGridTextColumn Header="Home"
                                                                        Binding="{Binding Home, StringFormat={}{0:0.###}}"
                                                                        Width="90">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                                <Setter Property="Margin" Value="0,0,12,0"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="Away"
                                                                        Binding="{Binding Away, StringFormat={}{0:0.###}}"
                                                                        Width="90">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                                <Setter Property="Margin" Value="0,0,12,0"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="Diff"
                    Binding="{Binding Diff, StringFormat={}{0:0.###}}"
                    Width="90"
                    CanUserSort="False">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                                <Setter Property="Margin" Value="0,0,12,0"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Diff, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Diff, Converter={StaticResource LessThanZeroConverter}}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                            <TextBox x:Name="FeaturesDebug" Visibility="Collapsed"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <!-- ── Tab 2: About Model ── -->
                                <TabItem Header="About Model">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                                        <StackPanel>

                                            <!-- Two info cards in a row -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Algorithm card -->
                                                <materialDesign:Card Grid.Column="0"
                         Padding="16"
                         Margin="0,0,6,0"
                         UniformCornerRadius="8"
                         materialDesign:ElevationAssist.Elevation="Dp1">
                                                    <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                                                        <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                                                            <materialDesign:PackIcon Kind="Brain"
                                         Width="18" Height="18"
                                         VerticalAlignment="Center"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                         Margin="0,0,8,0"/>
                                                            <TextBlock Text="Algorithm"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                                                        </StackPanel>

                                                        <!-- Icon badge -->
                                                        <Border Width="100" Height="100"
                    CornerRadius="50"
                    Background="{DynamicResource SecondaryHueMidBrush}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16">
                                                            <materialDesign:PackIcon Kind="TuneVariant"
                                         Width="48" Height="48"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                                        </Border>

                                                        <TextBlock Text="OVA + FastTree"
                       FontSize="15" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
                                                        <TextBlock Text="ML.NET · .NET 8"
                       FontSize="12" Opacity="0.55"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
                                                        <TextBlock Text="14 features · last 5 games"
                       FontSize="12" Opacity="0.55"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
                                                        <TextBlock Text="Time-based split · 2015/16"
                       FontSize="12" Opacity="0.55"
                       HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </materialDesign:Card>

                                                <!-- Performance card -->
                                                <materialDesign:Card Grid.Column="1"
                         Padding="16"
                         Margin="6,0,0,0"
                         UniformCornerRadius="8"
                         materialDesign:ElevationAssist.Elevation="Dp1">
                                                    <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                                                        <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                                                            <materialDesign:PackIcon Kind="ChartBar"
                                         Width="18" Height="18"
                                         VerticalAlignment="Center"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                         Margin="0,0,8,0"/>
                                                            <TextBlock Text="Performance"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                                                        </StackPanel>

                                                        <Grid Width="100" Height="100"
                  HorizontalAlignment="Center"
                  Margin="0,0,0,16">
                                                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             Value="44.6" Maximum="100"
                             Width="100" Height="100"
                             Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                <TextBlock Text="44.6%"
                               FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                                                                <TextBlock Text="Accuracy"
                               FontSize="10" Opacity="0.55"
                               HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Grid>

                                                        <TextBlock Text="Baseline: ~45%"
                       FontSize="12" Opacity="0.55"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
                                                        <TextBlock Text="Test: 2015 / 2016"
                       FontSize="12" Opacity="0.55"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
                                                        <TextBlock Text="Away · Draw · Home"
                       FontSize="12" Opacity="0.55"
                       HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </materialDesign:Card>

                                            </Grid>

                                            <!-- Note -->
                                            <Border Padding="14"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource SecondaryAccentBrush}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="InformationOutline"
                                                                             Width="16" Height="16"
                                                                             VerticalAlignment="Top"
                                                                             Margin="0,1,10,0"
                                                                             Opacity="0.7"/>
                                                    <TextBlock TextWrapping="Wrap"
                                                               FontSize="12"
                                                               Opacity="0.75"
                                                               Text="Football outcomes are inherently difficult to predict. A micro accuracy of ~44.6% is competitive given that the naive baseline (always predicting Home Win) achieves ~45%. The model captures relative team form rather than absolute team strength."/>
                                                </StackPanel>
                                            </Border>

                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>

                        </Border>

                        <!-- Empty State -->
                        <Border x:Name="EmptyState"
                                Grid.Row="1"
                                Grid.RowSpan="3"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                                MinHeight="{Binding ActualHeight,
                                           RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                Padding="32,24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Central content block -->
                                <StackPanel Grid.Row="0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">

                                    <!-- Icon in a round badge -->
                                    <Border Width="120" Height="120"
                                            CornerRadius="60"
                                            Background="{DynamicResource SecondaryHueMidBrush}"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,24">
                                        <materialDesign:PackIcon Kind="SoccerField"
                                                                 Width="60" Height="60"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                 Opacity="0.85"/>
                                    </Border>

                                    <TextBlock Text="Ready to predict"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Opacity="0.7"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="Select a season and both teams, then press Predict Match"
                                               FontSize="13"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Opacity="0.45"
                                               LineHeight="22"
                                               MaxWidth="320"
                                               Margin="0,0,0,24"/>

                                    <!-- Random Match button -->
                                    <Button x:Name="RandomBtn"
                                            Click="RandomBtn_Click"
                                            MouseEnter="RandomBtn_MouseEnter"
                                            Height="40"
                                            FontSize="13"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                            BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                            Cursor="Hand"
                                            HorizontalAlignment="Center"
                                            Width="220"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            Margin="0,0,0,40">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon x:Name="RandomIcon"
                                                                     Kind="DiceMultiple"
                                                                     Width="18" Height="18"
                                                                     VerticalAlignment="Center"
                                                                     Margin="0,0,8,0"/>
                                            <TextBlock Text="Surprise Me" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- How it works -->
                                    <Grid HorizontalAlignment="Center" MaxWidth="580">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Step 1 -->
                                        <Border Grid.Column="0"
                                                Padding="16,14"
                                                CornerRadius="10"
                                                Background="{DynamicResource MaterialDesignToolBarBackground}">
                                            <StackPanel HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Soccer"
                                                                         Width="24" Height="24"
                                                                         HorizontalAlignment="Center"
                                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                         Margin="0,0,0,8"/>
                                                <TextBlock Text="Select Match"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,0,4"/>
                                                <TextBlock Text="11 European leagues · 25,000+ matches"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           Opacity="0.55"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Step 2 -->
                                        <Border Grid.Column="2"
                                                Padding="16,14"
                                                CornerRadius="10"
                                                Background="{DynamicResource MaterialDesignToolBarBackground}">
                                            <StackPanel HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Brain"
                                                                         Width="24" Height="24"
                                                                         HorizontalAlignment="Center"
                                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                         Margin="0,0,0,8"/>
                                                <TextBlock Text="Crunch Data"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,0,4"/>
                                                <TextBlock Text="14 dynamic features · last 5 games"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           Opacity="0.55"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Step 3 -->
                                        <Border Grid.Column="4"
                                                Padding="16,14"
                                                CornerRadius="10"
                                                Background="{DynamicResource MaterialDesignToolBarBackground}">
                                            <StackPanel HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="ChartBar"
                                                                         Width="24" Height="24"
                                                                         HorizontalAlignment="Center"
                                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                         Margin="0,0,0,8"/>
                                                <TextBlock Text="Get Prediction"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,0,4"/>
                                                <TextBlock Text="FastTree OVA · Home / Draw / Away"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           Opacity="0.55"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                    </Grid>
                                </StackPanel>

                                <!-- Quick Stats panel at bottom -->
                                <Border Grid.Row="1"
                                        Padding="20,12"
                                        CornerRadius="10"
                                        Background="{DynamicResource MaterialDesignToolBarBackground}"
                                        Margin="0,16,0,0">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="DatabaseOutline"
                                                                 Width="16" Height="16"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                 Margin="0,0,8,0"/>
                                        <TextBlock x:Name="QuickStatsText"
                                                   FontSize="12"
                                                   Opacity="0.6"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </Border>

                    </Grid>
                </ScrollViewer>
            </materialDesign:Card>

        </Grid>

        <!-- ═══════════════════════════════════════════
             STATUS BAR
        ════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,1,0,0">
            <Grid Margin="22,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center"
                                             Opacity="0.45"
                                             Margin="0,0,7,0"/>
                    <TextBlock x:Name="StatusText"
                               FontSize="12" Opacity="0.6"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
