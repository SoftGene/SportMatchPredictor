<Window x:Class="SportMatchPredictor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="SportMatchPredictor"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontSize="14"
        Background="{DynamicResource MaterialDesignBackground}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════
             HEADER BAR
        ════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryHueDarkBrush}">
            <Grid Margin="28,0,24,0">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <materialDesign:PackIcon Kind="TuneVariant"
                                             Width="26" Height="26"
                                             Foreground="White"
                                             VerticalAlignment="Center"
                                             Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SportMatchPredictor"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Probabilistic match outcome prediction  ·  OVA + FastTree  ·  time-aware features"
                                   Foreground="White"
                                   Opacity="0.65"
                                   FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Background="#26FFFFFF"
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Memory"
                                                 Width="15" Height="15"
                                                 Foreground="White"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,7,0"/>
                        <TextBlock Text="model.zip  ·  .NET 8  ·  ML.NET"
                                   Foreground="White"
                                   Opacity="0.9"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════
             MAIN CONTENT
        ════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="20,16,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────
                 LEFT CARD — Match Configuration
            ──────────────────────────────────────── -->
            <materialDesign:Card Grid.Column="0"
                                 materialDesign:ElevationAssist.Elevation="Dp3"
                                 UniformCornerRadius="12"
                                 Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Card header band -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource PrimaryHueMidBrush}"
                            CornerRadius="12,12,0,0"
                            Padding="22,16">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Soccer"
                                                     Width="22" Height="22"
                                                     Foreground="White"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,10,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Match Configuration"
                                           Foreground="White"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Select teams and season"
                                           Foreground="White"
                                           Opacity="0.7"
                                           FontSize="11"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Form -->
                    <StackPanel Grid.Row="1" Margin="22,20,22,4">

                        <TextBlock Text="SEASON"
                                   FontSize="10" FontWeight="Medium"
                                   Opacity="0.5" Margin="0,0,0,6"/>
                        <ComboBox x:Name="SeasonCombo"
                                  Style="{StaticResource SelectionComboBoxStyle}"
                                  materialDesign:HintAssist.Hint="Select season"                                  
                                  Margin="0,0,0,20" SelectionChanged="SeasonCombo_SelectionChanged"/>

                        <TextBlock Text="HOME TEAM"
                                   FontSize="10" FontWeight="Medium"
                                   Opacity="0.5" Margin="0,0,0,6"/>
                        <ComboBox x:Name="HomeTeamCombo"
                                  Style="{StaticResource SelectionComboBoxStyle}"
                                  IsEditable="True"
                                  materialDesign:HintAssist.Hint="Select home team"
                                  Margin="0,0,0,0"/>

                        <!-- VS divider -->
                        <Grid Margin="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Height="1"
                                       VerticalAlignment="Center"
                                       Fill="{DynamicResource MaterialDesignDivider}"/>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource PrimaryHueMidBrush}"
                                    CornerRadius="20"
                                    Width="38" Height="38"
                                    Margin="10,0">
                                <TextBlock Text="VS"
                                           Foreground="White"
                                           FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Rectangle Grid.Column="2" Height="1"
                                       VerticalAlignment="Center"
                                       Fill="{DynamicResource MaterialDesignDivider}"/>
                        </Grid>

                        <TextBlock Text="AWAY TEAM"
                                   FontSize="10" FontWeight="Medium"
                                   Opacity="0.5" Margin="0,0,0,6"/>
                        <ComboBox x:Name="AwayTeamCombo"
                                  Style="{StaticResource SelectionComboBoxStyle}"
                                  IsEditable="True"
                                  materialDesign:HintAssist.Hint="Select away team"
                                  Margin="0,0,0,24"/>

                        <!-- Predict — primary button -->
                        <Button x:Name="PredictBtn"
                                Content="PREDICT MATCH"
                                Click="PredictBtn_Click"
                                Height="50"
                                FontSize="14"
                                FontWeight="Bold"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                materialDesign:ElevationAssist.Elevation="Dp4"
                                Margin="0,0,0,10"/>

                        <!-- Clear — secondary button -->
                        <Button x:Name="ClearBtn"
                                Content="Clear Selection"
                                Click="ClearBtn_Click"
                                Height="40"
                                FontSize="13"
                                Background="Transparent"
                                BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                BorderThickness="1.5"
                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                materialDesign:ElevationAssist.Elevation="Dp0"/>

                    </StackPanel>

                    <!-- Options footer -->
                    <Border Grid.Row="2"
                            CornerRadius="0,0,12,12"
                            Background="{DynamicResource MaterialDesignToolBarBackground}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="0,1,0,0"
                            Padding="22,14">
                        <StackPanel>
                            <TextBlock Text="OPTIONS"
                                       FontSize="10" FontWeight="Medium"
                                       Opacity="0.45" Margin="0,0,0,10"/>
                            <CheckBox x:Name="IncludeFeatureSummary"
                                      Content="Show feature summary after prediction"
                                      IsChecked="True"
                                      VerticalContentAlignment="Center"
                                      Style="{StaticResource OptionCheckBoxStyle}"
                                      Margin="0,0,0,6" Checked="IncludeFeatureSummary_Checked"/>
                            <CheckBox x:Name="UseTimeAwareFeatures"
                                      Content="Use time-aware feature computation"
                                      IsChecked="True"
                                      Style="{StaticResource OptionCheckBoxStyle}"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </materialDesign:Card>

            <!-- ─────────────────────────────────────
                 RIGHT CARD — Prediction Result
            ──────────────────────────────────────── -->
            <materialDesign:Card Grid.Column="1"
                                 materialDesign:ElevationAssist.Elevation="Dp3"
                                 UniformCornerRadius="12"
                                 Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top bar -->
                    <Border Grid.Row="0"
                            Padding="26,16"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="PollBox"
                                                         Width="20" Height="20"
                                                         VerticalAlignment="Center"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                         Margin="0,0,10,0"/>
                                <TextBlock Text="Prediction Result"
                                           FontSize="15" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="PredictedDetailsText"
                                       Margin="30,6,0,0"
                                       Opacity="0.58"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Hero outcome block -->
                    <Border Grid.Row="1"
                            Margin="26,18,26,0"
                            Padding="24,22"
                            CornerRadius="14"
                            Background="{DynamicResource SurfaceTintBrush}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Margin="0,0,22,0">
                                <TextBlock Text="Predicted outcome"
                                           FontSize="12"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                <TextBlock x:Name="PredictedLabelText"
                                           Text="—"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryHueMidBrush}"
                                           Margin="0,4,0,8"/>
                                <TextBlock Text="Based on recent form and engineered match features."
                                           FontSize="12"
                                           Opacity="0.6"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource PrimaryHueDarkBrush}"
                                    CornerRadius="12"
                                    Padding="18,16">
                                <StackPanel>
                                    <TextBlock Text="CONFIDENCE"
                                               Foreground="White"
                                               Opacity="0.68"
                                               FontSize="10"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ConfidenceText"
                                               Foreground="White"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Margin="0,6,0,4"/>
                                    <TextBlock Text="Highest class probability"
                                               Foreground="White"
                                               Opacity="0.68"
                                               FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Probability panel -->
                    <Border Grid.Row="2"
                            Margin="26,18,26,0"
                            Padding="20"
                            CornerRadius="12"
                            Background="{DynamicResource MaterialDesignPaper}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="OUTCOME PROBABILITIES"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Opacity="0.45"
                                           VerticalAlignment="Center"/>
                                <Rectangle Width="1"
                                           Height="12"
                                           Fill="{DynamicResource MaterialDesignDivider}"
                                           Margin="12,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Softmax distribution"
                                           FontSize="11"
                                           Opacity="0.45"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Margin="0,16,0,0"
                                    Padding="14,12"
                                    CornerRadius="10"
                                    Background="{DynamicResource DangerSurfaceBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="72"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal"
                                                Grid.Column="0"
                                                VerticalAlignment="Center">
                                        <Border Width="12"
                                                Height="12"
                                                CornerRadius="6"
                                                Background="{DynamicResource DangerBrush}"
                                                Margin="0,0,10,0"/>
                                        <TextBlock Text="Away Win"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <ProgressBar x:Name="AwayBar"
                                                 Grid.Column="1"
                                                 Height="10"
                                                 Minimum="0"
                                                 Maximum="1"
                                                 Background="#33EF5350"
                                                 Foreground="{DynamicResource DangerBrush}"
                                                 VerticalAlignment="Center"/>
                                    <TextBlock x:Name="AwayPct"
                                               Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource DangerBrush}"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,10,0,0"
                                    Padding="14,12"
                                    CornerRadius="10"
                                    Background="{DynamicResource WarnSurfaceBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="72"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal"
                                                Grid.Column="0"
                                                VerticalAlignment="Center">
                                        <Border Width="12"
                                                Height="12"
                                                CornerRadius="6"
                                                Background="{DynamicResource WarnBrush}"
                                                Margin="0,0,10,0"/>
                                        <TextBlock Text="Draw"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <ProgressBar x:Name="DrawBar"
                                                 Grid.Column="1"
                                                 Height="10"
                                                 Minimum="0"
                                                 Maximum="1"
                                                 Background="#33FFA726"
                                                 Foreground="{DynamicResource WarnBrush}"
                                                 VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DrawPct"
                                               Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource WarnBrush}"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,10,0,0"
                                    Padding="14,12"
                                    CornerRadius="10"
                                    Background="{DynamicResource SuccessSurfaceBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="72"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal"
                                                Grid.Column="0"
                                                VerticalAlignment="Center">
                                        <Border Width="12"
                                                Height="12"
                                                CornerRadius="6"
                                                Background="{DynamicResource SuccessBrush}"
                                                Margin="0,0,10,0"/>
                                        <TextBlock Text="Home Win"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <ProgressBar x:Name="HomeBar"
                                                 Grid.Column="1"
                                                 Height="10"
                                                 Minimum="0"
                                                 Maximum="1"
                                                 Background="#3366BB6A"
                                                 Foreground="{DynamicResource SuccessBrush}"
                                                 VerticalAlignment="Center"/>
                                    <TextBlock x:Name="HomePct"
                                               Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource SuccessBrush}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Features debug expander -->
                    <ScrollViewer Grid.Row="3"
                                  Margin="26,16,26,20"
                                  VerticalScrollBarVisibility="Auto">
                        <Expander IsExpanded="True"
                                  materialDesign:ExpanderAssist.HorizontalHeaderPadding="0,6,0,6">
                            <Expander.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="28"
                                            Height="28"
                                            CornerRadius="8"
                                            Background="{DynamicResource SurfaceTintBrush}"
                                            VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="CodeBraces"
                                                                 Width="16"
                                                                 Height="16"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Computed Features"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Readable model inputs for the current prediction"
                                                   FontSize="11"
                                                   Opacity="0.55"/>
                                    </StackPanel>
                                </Grid>
                            </Expander.Header>
                            <Border Margin="0,10,0,0"
                                    Padding="18"
                                    CornerRadius="12"
                                    Background="{DynamicResource MaterialDesignPaper}"
                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Feature Summary"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="Generated statistics used by the model."
                                                       FontSize="11"
                                                       Opacity="0.55"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource MaterialDesignToolBarBackground}"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="DEBUG"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryHueDarkBrush}"/>
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Background="{DynamicResource MaterialDesignToolBarBackground}"
                                            CornerRadius="10"
                                            Padding="14">
                                        <TextBox x:Name="FeaturesDebug"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="0"
                                                 FontFamily="Consolas"
                                                 FontSize="12.5"
                                                 Opacity="0.9"
                                                 VerticalScrollBarVisibility="Disabled"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Expander>
                    </ScrollViewer>

                </Grid>
            </materialDesign:Card>

        </Grid>

        <!-- ═══════════════════════════════════════════
             STATUS BAR
        ════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,1,0,0">
            <Grid Margin="22,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center"
                                             Opacity="0.45"
                                             Margin="0,0,7,0"/>
                    <TextBlock x:Name="StatusText"
                               FontSize="12" Opacity="0.6"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="SportMatchPredictor  ·  .NET 8  ·  ML.NET  ·  OVA + FastTree"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Opacity="0.35"/>
            </Grid>
        </Border>

    </Grid>
</Window>
