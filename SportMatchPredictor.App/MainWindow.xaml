<Window x:Class="SportMatchPredictor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:SportMatchPredictor.App.Converters"
        Title="SportMatchPredictor"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontSize="14"
        Background="{DynamicResource MaterialDesignBackground}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <converters:PathToImageSourceConverter x:Key="PathToImageSourceConverter"/>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
        <converters:LessThanZeroConverter x:Key="LessThanZeroConverter"/>
        <DataTemplate x:Key="TeamItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Grid Width="24" Height="24" Margin="0,0,8,0">
                    <Border CornerRadius="12" Background="{DynamicResource PrimaryHueLightBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LogoPath}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Initial}"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryHueDarkBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Image RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Source"
                                        Value="{Binding LogoPath, Converter={StaticResource PathToImageSourceConverter}}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LogoPath}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Grid>
                <TextBlock Text="{Binding TeamLongName}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource MaterialDesignBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════
             HEADER BAR
        ════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryHueDarkBrush}">
            <Grid Margin="28,0,24,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <materialDesign:PackIcon Kind="TuneVariant"
                                             Width="26" Height="26"
                                             Foreground="White"
                                             VerticalAlignment="Center"
                                             Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SportMatchPredictor"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Probabilistic match outcome prediction  ·  OVA + FastTree  ·  time-aware features"
                                   Foreground="White"
                                   Opacity="0.65"
                                   FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Background="#26FFFFFF"
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Memory"
                                                 Width="15" Height="15"
                                                 Foreground="White"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,7,0"/>
                        <TextBlock Text="model.zip"
                                   Foreground="White"
                                   Opacity="0.9"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button x:Name="ThemeToggleBtn"
                        Click="ThemeToggleBtn_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="38"
                        Height="38"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="#40FFFFFF"
                        BorderThickness="0"
                        materialDesign:ButtonAssist.CornerRadius="19"
                        materialDesign:ElevationAssist.Elevation="Dp0"
                        ToolTip="Toggle dark/light theme"
                        Margin="0,0,110,0">
                    <materialDesign:PackIcon x:Name="ThemeIcon"
                                             Kind="WeatherNight"
                                             Width="20" Height="20"
                                             Foreground="White"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════
             MAIN CONTENT
        ════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="20,16,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────
                 LEFT CARD — Match Configuration
            ──────────────────────────────────────── -->
            <materialDesign:Card Grid.Column="0"
                                 materialDesign:ElevationAssist.Elevation="Dp3"
                                 UniformCornerRadius="12"
                                 Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Card header band -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource PrimaryHueMidBrush}"
                            CornerRadius="12,12,0,0"
                            Padding="22,16">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Soccer"
                                                     Width="22" Height="22"
                                                     Foreground="White"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,10,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Match Configuration"
                                           Foreground="White"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Select teams and season"
                                           Foreground="White"
                                           Opacity="0.7"
                                           FontSize="11"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Form -->
                    <StackPanel Grid.Row="1" Margin="22,20,22,4">

                        <TextBlock Text="SEASON"
                                   FontSize="10" FontWeight="Medium"
                                   Opacity="0.5" Margin="0,0,0,6"/>
                        <ComboBox x:Name="SeasonCombo"
                                  Style="{StaticResource SelectionComboBoxStyle}"
                                  materialDesign:HintAssist.Hint="Select season"
                                  Margin="0,0,0,20"
                                  SelectionChanged="SeasonCombo_SelectionChanged"/>

                        <!-- Hidden ComboBoxes — kept for logic compatibility -->
                        <ComboBox x:Name="HomeTeamCombo"
          Visibility="Collapsed"
          IsEditable="True"
          TextSearch.TextPath="TeamLongName"
          ItemTemplate="{StaticResource TeamItemTemplate}"/>
                        <ComboBox x:Name="AwayTeamCombo"
          Visibility="Collapsed"
          IsEditable="True"
          TextSearch.TextPath="TeamLongName"
          ItemTemplate="{StaticResource TeamItemTemplate}"/>

                        <!-- Team poster cards -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Home team card -->
                            <Button Grid.Column="0"
            x:Name="HomeTeamCard"
            Click="HomeTeamCard_Click"
            Padding="0"
            BorderThickness="1.5"
            BorderBrush="{DynamicResource AppOutlineBrush}"
            Background="{DynamicResource MaterialDesignPaper}"
            materialDesign:ButtonAssist.CornerRadius="12"
            materialDesign:ElevationAssist.Elevation="Dp1"
            Height="180"
            Cursor="Hand">
                                <Grid>
                                    <!-- Empty state -->
                                    <StackPanel x:Name="HomeEmptyState"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Soccer"
                                         Width="36" Height="36"
                                         HorizontalAlignment="Center"
                                         Foreground="{DynamicResource MaterialDesignDivider}"
                                         Margin="0,0,0,8"/>
                                        <TextBlock Text="Select team"
                           FontSize="12"
                           Opacity="0.4"
                           HorizontalAlignment="Center"/>
                                        <TextBlock Text="Tap to browse"
                           FontSize="10"
                           Opacity="0.3"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Selected state -->
                                    <StackPanel x:Name="HomeSelectedState"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="10">
                                        <Grid Width="56" Height="56"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10">
                                            <Border x:Name="HomeBadge"
                            CornerRadius="28"
                            Background="{DynamicResource SecondaryHueMidBrush}">
                                                <TextBlock x:Name="HomeInitial"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryHueDarkBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                                            </Border>
                                            <Image x:Name="HomeLogoCard"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Visibility="Collapsed"/>
                                        </Grid>
                                        <TextBlock x:Name="HomeTeamName"
                           FontSize="12" FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           MaxWidth="110"/>
                                        <Border Background="{DynamicResource PrimaryHueMidBrush}"
                        CornerRadius="4"
                        Padding="8,3"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Center">
                                            <TextBlock Text="Change"
                               Foreground="White"
                               FontSize="10"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <!-- Swap button -->
                            <Button Grid.Column="1"
            x:Name="SwapBtn"
            Click="SwapBtn_Click"
            Width="38" Height="38"
            Margin="8,0"
            Background="{DynamicResource PrimaryHueMidBrush}"
            BorderThickness="0"
            Padding="0"
            materialDesign:ButtonAssist.CornerRadius="20"
            materialDesign:ElevationAssist.Elevation="Dp2"
            ToolTip="Swap teams">
                                <materialDesign:PackIcon Kind="SwapHorizontal"
                                 Width="20" Height="20"
                                 Foreground="White"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                            </Button>

                            <!-- Away team card -->
                            <Button Grid.Column="2"
            x:Name="AwayTeamCard"
            Click="AwayTeamCard_Click"
            Padding="0"
            BorderThickness="1.5"
            BorderBrush="{DynamicResource AppOutlineBrush}"
            Background="{DynamicResource MaterialDesignPaper}"
            materialDesign:ButtonAssist.CornerRadius="12"
            materialDesign:ElevationAssist.Elevation="Dp1"
            Height="180"
            Cursor="Hand">
                                <Grid>
                                    <!-- Empty state -->
                                    <StackPanel x:Name="AwayEmptyState"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Soccer"
                                         Width="36" Height="36"
                                         HorizontalAlignment="Center"
                                         Foreground="{DynamicResource MaterialDesignDivider}"
                                         Margin="0,0,0,8"/>
                                        <TextBlock Text="Select team"
                           FontSize="12"
                           Opacity="0.4"
                           HorizontalAlignment="Center"/>
                                        <TextBlock Text="Tap to browse"
                           FontSize="10"
                           Opacity="0.3"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Selected state -->
                                    <StackPanel x:Name="AwaySelectedState"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="10">
                                        <Grid Width="56" Height="56"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10">
                                            <Border x:Name="AwayBadgeCard"
                            CornerRadius="28"
                            Background="{DynamicResource SecondaryHueMidBrush}">
                                                <TextBlock x:Name="AwayInitial"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryHueDarkBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                                            </Border>
                                            <Image x:Name="AwayLogoCard"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Visibility="Collapsed"/>
                                        </Grid>
                                        <TextBlock x:Name="AwayTeamName"
                           FontSize="12" FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           MaxWidth="110"/>
                                        <Border Background="{DynamicResource PrimaryHueMidBrush}"
                        CornerRadius="4"
                        Padding="8,3"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Center">
                                            <TextBlock Text="Change"
                               Foreground="White"
                               FontSize="10"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Button>

                        </Grid>

                        <!-- Labels -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="54"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
               Text="HOME TEAM"
               FontSize="10" FontWeight="Medium"
               Opacity="0.5"
               HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
               Text="AWAY TEAM"
               FontSize="10" FontWeight="Medium"
               Opacity="0.5"
               HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- Predict — primary button -->
                        <Button x:Name="PredictBtn"
                                Content="PREDICT MATCH"
                                Click="PredictBtn_Click"
                                IsEnabled="False"
                                Height="50"
                                FontSize="14"
                                FontWeight="Bold"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                materialDesign:ElevationAssist.Elevation="Dp4"
                                Margin="0,0,0,10"/>

                        <!-- Clear — secondary button -->
                        <Button x:Name="ClearBtn"
                                Content="Clear Selection"
                                Click="ClearBtn_Click"
                                Height="40"
                                FontSize="13"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                Cursor="Hand"
                                materialDesign:ButtonAssist.CornerRadius="8"/>

                        <!-- Recent Predictions History -->
                        <TextBlock Text="RECENT PREDICTIONS"
                                   FontSize="10" FontWeight="Medium"
                                   Opacity="0.5" Margin="0,16,0,6"/>
                        <ListBox x:Name="HistoryList"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0"
                                 SelectionChanged="HistoryList_SelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <!-- Neutralise the default selection highlight -->
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin"  Value="0,0,0,6"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Focusable" Value="True"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Cursor="Hand"
                                            Background="{DynamicResource CardSurfaceBrush}"
                                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            RenderTransformOrigin="0.5,0.5"
                                            ToolTip="Click to re-run this prediction">
                                        <Border.RenderTransform>
                                            <TranslateTransform Y="0"/>
                                        </Border.RenderTransform>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <EventTrigger RoutedEvent="MouseEnter">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                                 To="-1" Duration="0:0:0.18"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                    <EventTrigger RoutedEvent="MouseLeave">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                                 To="0" Duration="0:0:0.22"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Outcome stripe -->
                                            <Border Grid.Column="0"
                                                    Background="{Binding OutcomeBrush}"
                                                    CornerRadius="8,0,0,8"/>

                                            <!-- Content -->
                                            <Grid Grid.Column="1" Margin="10,8,10,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Row 1: Home [logo] vs [logo] Away -->
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- HOME block -->
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <Grid Width="18" Height="18" Margin="0,0,6,0">
                                                            <Border CornerRadius="9"
                                                                    Background="{DynamicResource PrimaryHueLightBrush}">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HomeLogo}" Value="{x:Null}">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding HomeInitial}"
                                                                           FontSize="9" FontWeight="Bold"
                                                                           Foreground="{DynamicResource PrimaryHueDarkBrush}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>
                                                            <Image Source="{Binding HomeLogo, Converter={StaticResource PathToImageSourceConverter}}"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding HomeShort}"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource MaterialDesignBody}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <!-- vs -->
                                                    <TextBlock Grid.Column="1" Text="vs"
                                                               FontSize="9" FontStyle="Italic"
                                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,6,0"/>

                                                    <!-- AWAY block -->
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding AwayShort}"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource MaterialDesignBody}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,0,6,0"/>
                                                        <Grid Width="18" Height="18">
                                                            <Border CornerRadius="9"
                                                                    Background="{DynamicResource PrimaryHueLightBrush}">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding AwayLogo}" Value="{x:Null}">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding AwayInitial}"
                                                                           FontSize="9" FontWeight="Bold"
                                                                           Foreground="{DynamicResource PrimaryHueDarkBrush}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>
                                                            <Image Source="{Binding AwayLogo, Converter={StaticResource PathToImageSourceConverter}}"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Row 2: outcome · confidence · season -->
                                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                                                    <Ellipse Width="7" Height="7"
                                                             Fill="{Binding OutcomeBrush}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding OutcomeText}"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{Binding OutcomeBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="5,0,0,0"/>
                                                    <Border Background="{DynamicResource SurfaceTintBrush}"
                                                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Padding="6,1"
                                                            Margin="8,0,0,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ConfidenceText}"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Season}"
                                                               FontSize="9" Opacity="0.55"
                                                               Foreground="{DynamicResource MaterialDesignBody}"
                                                               VerticalAlignment="Center"
                                                               Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <!-- Branding footer -->
                    <Border Grid.Row="2"
                            CornerRadius="0,0,12,12"
                            Background="{DynamicResource MaterialDesignToolBarBackground}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="0,1,0,0"
                            Padding="22,14">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Soccer"
                                                     Width="20" Height="20"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,12,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Sport Match Predictor"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                <TextBlock Text="v1.0  ·  Diploma project"
                                           FontSize="11" Opacity="0.5" Margin="0,2,0,0"/>
                                <TextBlock Text="ML.NET  ·  .NET 8  ·  OVA + FastTree"
                                           FontSize="11" Opacity="0.5" Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </Grid>
            </materialDesign:Card>

            <!-- ─────────────────────────────────────
                 RIGHT CARD — Prediction Result
            ──────────────────────────────────────── -->
            <materialDesign:Card Grid.Column="1"
                                 materialDesign:ElevationAssist.Elevation="Dp3"
                                 UniformCornerRadius="12"
                                 Margin="10,0,0,0">
                <ScrollViewer x:Name="ResultScrollViewer"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid MinHeight="640">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Top bar -->
                        <Border x:Name="ResultHeader" Grid.Row="0"
                                Padding="26,16"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="PollBox"
                                                             Width="20" Height="20"
                                                             VerticalAlignment="Center"
                                                             Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                             Margin="0,0,10,0"/>
                                    <TextBlock Text="Prediction Result"
                                               FontSize="15" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="PredictedDetailsText"
                                           Margin="30,6,0,0"
                                           Opacity="0.58"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Hero outcome block -->
                        <Border x:Name="HeroBlock" Grid.Row="1"
                                Margin="26,18,26,0"
                                Padding="24,22"
                                CornerRadius="14"
                                Background="{DynamicResource SurfaceTintBrush}"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="190"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            VerticalAlignment="Center"
                                            Margin="0,0,22,0">
                                    <TextBlock Text="Predicted outcome"
                                               FontSize="12"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,8" VerticalAlignment="Center">
                                        <Image x:Name="HomeLogo"
                                               Width="32" Height="32"
                                               Visibility="Collapsed"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <Image x:Name="AwayLogo"
                                               Width="32" Height="32"
                                               Visibility="Collapsed"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock x:Name="PredictedLabelText"
                                                   Text="—"
                                                   FontSize="34"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Image x:Name="AwayLogoRight"
                                               Width="32" Height="32"
                                               Visibility="Collapsed"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </StackPanel>
                                    <TextBlock Text="Based on recent form and engineered match features."
                                               FontSize="12"
                                               Opacity="0.6"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource PrimaryHueDarkBrush}"
                                        CornerRadius="12"
                                        Padding="18,16">
                                    <StackPanel>
                                        <TextBlock Text="CONFIDENCE"
                                                   Foreground="White"
                                                   Opacity="0.68"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="ConfidenceText"
                                                   Foreground="White"
                                                   FontSize="32"
                                                   FontWeight="Bold"
                                                   Margin="0,6,0,4"/>
                                        <TextBlock Text="Highest class probability"
                                                   Foreground="White"
                                                   Opacity="0.68"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Probability panel -->
                        <Border x:Name="ProbabilityBlock" Grid.Row="2"
                                Margin="26,18,26,0"
                                Padding="20"
                                CornerRadius="12"
                                Background="{DynamicResource MaterialDesignPaper}"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="OUTCOME PROBABILITIES"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.45"
                                               VerticalAlignment="Center"/>
                                    <Rectangle Width="1"
                                               Height="12"
                                               Fill="{DynamicResource MaterialDesignDivider}"
                                               Margin="12,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Softmax distribution"
                                               FontSize="11"
                                               Opacity="0.45"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Away probability -->
                                <Border x:Name="AwayBorder"
                                        Margin="0,16,0,0"
                                        Padding="14,12"
                                        CornerRadius="10"
                                        Background="{DynamicResource DangerSurfaceBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="72"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Width="12"
                                                    Height="12"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource DangerBrush}"
                                                    Margin="0,0,10,0"/>
                                            <TextBlock Text="Away Win"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <ProgressBar x:Name="AwayBar"
                                                     Grid.Column="1"
                                                     Height="10"
                                                     Minimum="0"
                                                     Maximum="1"
                                                     Background="#33EF5350"
                                                     Foreground="{DynamicResource DangerBrush}"
                                                     VerticalAlignment="Center"/>
                                        <TextBlock x:Name="AwayPct"
                                                   Grid.Column="2"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource DangerBrush}"/>
                                    </Grid>
                                </Border>

                                <!-- Draw probability -->
                                <Border x:Name="DrawBorder"
                                        Margin="0,10,0,0"
                                        Padding="14,12"
                                        CornerRadius="10"
                                        Background="{DynamicResource WarnSurfaceBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="72"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Width="12"
                                                    Height="12"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource WarnBrush}"
                                                    Margin="0,0,10,0"/>
                                            <TextBlock Text="Draw"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <ProgressBar x:Name="DrawBar"
                                                     Grid.Column="1"
                                                     Height="10"
                                                     Minimum="0"
                                                     Maximum="1"
                                                     Background="#33FFA726"
                                                     Foreground="{DynamicResource WarnBrush}"
                                                     VerticalAlignment="Center"/>
                                        <TextBlock x:Name="DrawPct"
                                                   Grid.Column="2"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource WarnBrush}"/>
                                    </Grid>
                                </Border>

                                <!-- Home probability -->
                                <Border x:Name="HomeBorder"
                                        Margin="0,10,0,0"
                                        Padding="14,12"
                                        CornerRadius="10"
                                        Background="{DynamicResource SuccessSurfaceBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="72"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Width="12"
                                                    Height="12"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource SuccessBrush}"
                                                    Margin="0,0,10,0"/>
                                            <TextBlock Text="Home Win"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <ProgressBar x:Name="HomeBar"
                                                     Grid.Column="1"
                                                     Height="10"
                                                     Minimum="0"
                                                     Maximum="1"
                                                     Background="#3366BB6A"
                                                     Foreground="{DynamicResource SuccessBrush}"
                                                     VerticalAlignment="Center"/>
                                        <TextBlock x:Name="HomePct"
                                                   Grid.Column="2"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource SuccessBrush}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Features and Model Info Tabs -->
                        <Border x:Name="TabBlock" Grid.Row="3"
                                Margin="26,16,26,20"
                                CornerRadius="12"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="1"
                                Background="{DynamicResource MaterialDesignPaper}">
                            <TabControl Style="{StaticResource MaterialDesignTabControl}"
                                        materialDesign:ColorZoneAssist.Mode="Custom"
                                        materialDesign:ColorZoneAssist.Foreground="{DynamicResource PrimaryHueMidBrush}"
                                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                                        Background="Transparent"
                                        ClipToBounds="True">
                                <TabControl.Resources>
                                    <Style TargetType="TabItem" BasedOn="{StaticResource GreenTabItemStyle}"/>
                                </TabControl.Resources>

                                <!-- ── Tab 1: Computed Features ── -->
                                <TabItem Header="Computed Features">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Margin="0,8,0,0"
                                                  Style="{StaticResource TabContentFadeInStyle}">
                                        <StackPanel Margin="4,0,4,12">
                                            <StackPanel.Resources>
                                                <!-- Force themed foreground so text is readable
                                                     in both light and dark themes -->
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground"
                                                            Value="{DynamicResource MaterialDesignBody}"/>
                                                </Style>
                                            </StackPanel.Resources>

                                            <!-- Card header -->
                                            <DockPanel LastChildFill="True" Margin="16,10,16,2">
                                                <TextBlock DockPanel.Dock="Left"
                                                           Text="Feature Summary"
                                                           FontSize="15" FontWeight="SemiBold"/>
                                            </DockPanel>
                                            <TextBlock Text="Head-to-head statistics engineered for this match"
                                                       FontSize="11" Opacity="0.55"
                                                       Margin="16,0,16,8"/>

                                            <!-- Column hint strip -->
                                            <Border Background="{DynamicResource SurfaceTintBrush}"
                                                    Margin="16,4,16,0" Padding="0,8"
                                                    CornerRadius="6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="48"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="110"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Grid.Column="1" Margin="14,0,14,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="2"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="40"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="HOME" FontSize="10" FontWeight="Bold"
                                                                   Foreground="{DynamicResource HomeValueBrush}"
                                                                   HorizontalAlignment="Right"/>
                                                        <TextBlock Grid.Column="4"
                                                                   Text="AWAY" FontSize="10" FontWeight="Bold"
                                                                   Foreground="{DynamicResource AwayValueBrush}"
                                                                   HorizontalAlignment="Left"/>
                                                    </Grid>
                                                    <TextBlock Grid.Column="2" Text="Δ vs HOME"
                                                               FontSize="10" FontWeight="Bold"
                                                               Opacity="0.6"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,0,12,0"/>
                                                </Grid>
                                            </Border>

                                            <!-- Metric rows -->
                                            <ItemsControl x:Name="FeaturesGrid"
                                                          Margin="16,4,16,0"
                                                          Background="Transparent"
                                                          BorderThickness="0">
                                                <ItemsControl.GroupStyle>
                                                    <GroupStyle>
                                                        <GroupStyle.HeaderTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontSize="10" FontWeight="Bold"
                                                                           Foreground="{DynamicResource MaterialDesignBody}"
                                                                           Opacity="0.7"
                                                                           Margin="4,8,0,2"
                                                                           Typography.Capitals="AllSmallCaps"/>
                                                            </DataTemplate>
                                                        </GroupStyle.HeaderTemplate>
                                                    </GroupStyle>
                                                </ItemsControl.GroupStyle>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="4,7"
                                                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                                BorderThickness="0,0,0,1"
                                                                Style="{StaticResource MetricRowHoverStyle}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="48"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="110"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Icon chip -->
                                                                <Border Grid.Column="0"
                                                                        Width="40" Height="40"
                                                                        CornerRadius="20"
                                                                        Background="{Binding CategoryBgBrush}"
                                                                        VerticalAlignment="Top">
                                                                    <materialDesign:PackIcon Kind="{Binding Icon}"
                                                                                             Width="20" Height="20"
                                                                                             Foreground="{Binding CategoryFgBrush}"
                                                                                             HorizontalAlignment="Center"
                                                                                             VerticalAlignment="Center"/>
                                                                </Border>

                                                                <!-- Body -->
                                                                <StackPanel Grid.Column="1" Margin="14,0,14,0">
                                                                    <DockPanel LastChildFill="False">
                                                                        <TextBlock DockPanel.Dock="Left"
                                                                                   Text="{Binding Metric}"
                                                                                   FontSize="14" FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                                                                        <Border DockPanel.Dock="Right"
                                                                                Background="{Binding CategoryBgBrush}"
                                                                                CornerRadius="10" Padding="8,2"
                                                                                VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Category}"
                                                                                       FontSize="10" FontWeight="Medium"
                                                                                       Foreground="{Binding CategoryFgBrush}"/>
                                                                        </Border>
                                                                    </DockPanel>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                                               Margin="0,1,0,6"/>

                                                                    <!-- Diverging bar -->
                                                                    <Grid Height="22">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="40"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="2"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="40"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <TextBlock Grid.Column="0"
                                                                                   Text="{Binding HomeText}"
                                                                                   FontSize="12" FontWeight="SemiBold"
                                                                                   Foreground="{Binding HomeValueBrush}"
                                                                                   HorizontalAlignment="Right"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="0,0,8,0"/>

                                                                        <!-- HOME track -->
                                                                        <Border Grid.Column="1"
                                                                                Background="{DynamicResource BarTrackBrush}"
                                                                                CornerRadius="5,0,0,5"
                                                                                Height="9"
                                                                                VerticalAlignment="Center">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="{Binding HomeEmptyStar}"/>
                                                                                    <ColumnDefinition Width="{Binding HomeFillStar}"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <Border Grid.Column="1"
                                                                                        Background="{Binding HomeBarBrush}"
                                                                                        CornerRadius="5,0,0,5"/>
                                                                            </Grid>
                                                                        </Border>

                                                                        <!-- Axis -->
                                                                        <Rectangle Grid.Column="2"
                                                                                   Width="2" Height="16"
                                                                                   Fill="{DynamicResource BarAxisBrush}"
                                                                                   VerticalAlignment="Center"/>

                                                                        <!-- AWAY track -->
                                                                        <Border Grid.Column="3"
                                                                                Background="{DynamicResource BarTrackBrush}"
                                                                                CornerRadius="0,5,5,0"
                                                                                Height="9"
                                                                                VerticalAlignment="Center">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="{Binding AwayFillStar}"/>
                                                                                    <ColumnDefinition Width="{Binding AwayEmptyStar}"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <Border Grid.Column="0"
                                                                                        Background="{Binding AwayBarBrush}"
                                                                                        CornerRadius="0,5,5,0"/>
                                                                            </Grid>
                                                                        </Border>

                                                                        <TextBlock Grid.Column="4"
                                                                                   Text="{Binding AwayText}"
                                                                                   FontSize="12" FontWeight="SemiBold"
                                                                                   Foreground="{Binding AwayValueBrush}"
                                                                                   HorizontalAlignment="Left"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="8,0,0,0"/>
                                                                    </Grid>
                                                                </StackPanel>

                                                                <!-- Delta pill -->
                                                                <Border Grid.Column="2"
                                                                        VerticalAlignment="Center"
                                                                        HorizontalAlignment="Right"
                                                                        Background="{Binding DeltaBg}"
                                                                        CornerRadius="14"
                                                                        Padding="10,6">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <materialDesign:PackIcon Kind="{Binding DeltaIcon}"
                                                                                                 Width="14" Height="14"
                                                                                                 Foreground="{Binding DeltaFg}"
                                                                                                 VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding DiffText}"
                                                                                   Margin="4,0,0,0"
                                                                                   FontSize="12" FontWeight="SemiBold"
                                                                                   Foreground="{Binding DeltaFg}"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Legend -->
                                            <DockPanel LastChildFill="True" Margin="20,14,20,6">
                                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                    <Ellipse Width="9" Height="9" Fill="{DynamicResource HomeValueBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Home advantage"
                                                               FontSize="11" Opacity="0.7"
                                                               Margin="6,0,16,0" VerticalAlignment="Center"/>
                                                    <Ellipse Width="9" Height="9" Fill="{DynamicResource AwayValueBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Away advantage"
                                                               FontSize="11" Opacity="0.7"
                                                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="Bars normalised per metric"
                                                           FontSize="11" Opacity="0.55"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>

                                            <TextBox x:Name="FeaturesDebug" Visibility="Collapsed"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <!-- ── Tab 2: About Model ── -->
                                <TabItem Header="About Model">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  Margin="0,8,0,0"
                                                  Style="{StaticResource TabContentFadeInStyle}">
                                        <StackPanel Margin="16,8,16,16">
                                            <StackPanel.Resources>
                                                <!-- Force all inner TextBlocks to use themed foreground
                                                     so they stay readable in both light and dark themes -->
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground"
                                                            Value="{DynamicResource MaterialDesignBody}"/>
                                                </Style>
                                            </StackPanel.Resources>

                                            <!-- Intro -->
                                            <TextBlock Text="About this model"
                                                       FontSize="16" FontWeight="SemiBold"/>
                                            <TextBlock Text="How the prediction is built, trained and evaluated."
                                                       FontSize="12" Opacity="0.55"
                                                       Margin="0,2,0,14"/>

                                            <!-- 2x2 Fact tiles -->
                                            <UniformGrid Rows="2" Columns="2">

                                                <!-- TILE 1: ALGORITHM -->
                                                <materialDesign:Card Style="{StaticResource InfoTileStyle}"
                                                                     Margin="0,0,7,7">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                            <Border Width="36" Height="36" CornerRadius="18"
                                                                    Background="{DynamicResource CatAttackBg}">
                                                                <materialDesign:PackIcon Kind="Brain"
                                                                                         Width="18" Height="18"
                                                                                         Foreground="{DynamicResource CatAttackFg}"
                                                                                         HorizontalAlignment="Center"
                                                                                         VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text="ALGORITHM"
                                                                       FontSize="10" FontWeight="Bold"
                                                                       Opacity="0.55"
                                                                       VerticalAlignment="Center"
                                                                       Margin="12,0,0,0"
                                                                       Typography.Capitals="AllSmallCaps"/>
                                                        </StackPanel>
                                                        <TextBlock Text="OVA + FastTree"
                                                                   FontSize="18" FontWeight="SemiBold"/>
                                                        <TextBlock TextWrapping="Wrap"
                                                                   FontSize="12" Opacity="0.6"
                                                                   Margin="0,4,0,0"
                                                                   Text="One-vs-All meta-learner over gradient-boosted decision trees. Outputs calibrated softmax over three classes."/>
                                                    </StackPanel>
                                                </materialDesign:Card>

                                                <!-- TILE 2: TRAINING DATA -->
                                                <materialDesign:Card Style="{StaticResource InfoTileStyle}"
                                                                     Margin="7,0,0,7">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                            <Border Width="36" Height="36" CornerRadius="18"
                                                                    Background="{DynamicResource CatDefenseBg}">
                                                                <materialDesign:PackIcon Kind="DatabaseOutline"
                                                                                         Width="18" Height="18"
                                                                                         Foreground="{DynamicResource CatDefenseFg}"
                                                                                         HorizontalAlignment="Center"
                                                                                         VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text="TRAINING DATA"
                                                                       FontSize="10" FontWeight="Bold"
                                                                       Opacity="0.55"
                                                                       VerticalAlignment="Center"
                                                                       Margin="12,0,0,0"
                                                                       Typography.Capitals="AllSmallCaps"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="2008 – 2016"
                                                                       FontSize="18" FontWeight="SemiBold"/>
                                                            <TextBlock Text="seasons" FontSize="12"
                                                                       Opacity="0.6" VerticalAlignment="Bottom"
                                                                       Margin="6,0,0,3"/>
                                                        </StackPanel>
                                                        <TextBlock Text="Time-aware train / validation split across European leagues."
                                                                   FontSize="12" Opacity="0.6"
                                                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                        <WrapPanel Margin="0,10,0,0">
                                                            <Border Background="{DynamicResource CatDefenseBg}"
                                                                    CornerRadius="10" Padding="8,2" Margin="0,0,6,4">
                                                                <TextBlock Text="Time-aware split" FontSize="10"
                                                                           FontWeight="Medium"
                                                                           Foreground="{DynamicResource CatDefenseFg}"/>
                                                            </Border>
                                                            <Border Background="{DynamicResource CatDefenseBg}"
                                                                    CornerRadius="10" Padding="8,2" Margin="0,0,6,4">
                                                                <TextBlock Text="No leakage" FontSize="10"
                                                                           FontWeight="Medium"
                                                                           Foreground="{DynamicResource CatDefenseFg}"/>
                                                            </Border>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </materialDesign:Card>

                                                <!-- TILE 3: FEATURES -->
                                                <materialDesign:Card Style="{StaticResource InfoTileStyle}"
                                                                     Margin="0,7,7,0">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                            <Border Width="36" Height="36" CornerRadius="18"
                                                                    Background="{DynamicResource CatFormBg}">
                                                                <materialDesign:PackIcon Kind="TuneVariant"
                                                                                         Width="18" Height="18"
                                                                                         Foreground="{DynamicResource CatFormFg}"
                                                                                         HorizontalAlignment="Center"
                                                                                         VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text="FEATURES"
                                                                       FontSize="10" FontWeight="Bold"
                                                                       Opacity="0.55"
                                                                       VerticalAlignment="Center"
                                                                       Margin="12,0,0,0"
                                                                       Typography.Capitals="AllSmallCaps"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="14" FontSize="18" FontWeight="SemiBold"/>
                                                            <TextBlock Text="engineered signals" FontSize="12"
                                                                       Opacity="0.6" VerticalAlignment="Bottom"
                                                                       Margin="6,0,0,3"/>
                                                        </StackPanel>
                                                        <TextBlock TextWrapping="Wrap"
                                                                   FontSize="12" Opacity="0.6"
                                                                   Margin="0,4,0,0"
                                                                   Text="Rolling-window form, goal-diff trends, head-to-head history, last-5-games aggregates."/>
                                                    </StackPanel>
                                                </materialDesign:Card>

                                                <!-- TILE 4: STACK -->
                                                <materialDesign:Card Style="{StaticResource InfoTileStyle}"
                                                                     Margin="7,7,0,0">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                            <Border Width="36" Height="36" CornerRadius="18"
                                                                    Background="{DynamicResource CatMomentumBg}">
                                                                <materialDesign:PackIcon Kind="CodeTags"
                                                                                         Width="18" Height="18"
                                                                                         Foreground="{DynamicResource CatMomentumFg}"
                                                                                         HorizontalAlignment="Center"
                                                                                         VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text="STACK"
                                                                       FontSize="10" FontWeight="Bold"
                                                                       Opacity="0.55"
                                                                       VerticalAlignment="Center"
                                                                       Margin="12,0,0,0"
                                                                       Typography.Capitals="AllSmallCaps"/>
                                                        </StackPanel>
                                                        <TextBlock Text="ML.NET · .NET 8"
                                                                   FontSize="18" FontWeight="SemiBold"/>
                                                        <TextBlock TextWrapping="Wrap"
                                                                   FontSize="12" Opacity="0.6"
                                                                   Margin="0,4,0,0">
                                                            <Run Text="WPF + MaterialDesignInXAML. Model persisted as "/>
                                                            <Run Text="model.zip" FontFamily="Consolas"
                                                                 Background="{DynamicResource SurfaceTintBrush}"/>
                                                            <Run Text="."/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </materialDesign:Card>
                                            </UniformGrid>

                                            <!-- PERFORMANCE STRIP -->
                                            <materialDesign:Card Margin="0,14,0,0"
                                                                 UniformCornerRadius="12"
                                                                 Padding="18,16"
                                                                 Background="{DynamicResource MaterialDesignPaper}"
                                                                 BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                                                 BorderThickness="1"
                                                                 materialDesign:ElevationAssist.Elevation="Dp0">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="ChartLine"
                                                                                 Width="14" Height="14"
                                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                                 VerticalAlignment="Center"/>
                                                        <TextBlock Text="MODEL PERFORMANCE"
                                                                   FontSize="10" FontWeight="Bold"
                                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                   Margin="6,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   Typography.Capitals="AllSmallCaps"/>
                                                        <TextBlock Text="· micro-accuracy on test set 2015/16"
                                                                   FontSize="10" Opacity="0.55"
                                                                   Margin="6,0,0,0"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <UniformGrid Rows="1" Columns="4" Margin="0,12,0,0">
                                                        <StackPanel Margin="0,0,16,0">
                                                            <TextBlock Text="ACCURACY"
                                                                       FontSize="10" FontWeight="Bold" Opacity="0.55"
                                                                       Typography.Capitals="AllSmallCaps"/>
                                                            <TextBlock Text="44.6%" FontSize="22" FontWeight="Bold"/>
                                                            <ProgressBar Value="44.6" Maximum="100"
                                                                         Height="4" Margin="0,4,0,0"
                                                                         Background="{DynamicResource MaterialDesignDivider}"
                                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                         BorderThickness="0"/>
                                                        </StackPanel>
                                                        <StackPanel Margin="0,0,16,0">
                                                            <TextBlock Text="BASELINE"
                                                                       FontSize="10" FontWeight="Bold" Opacity="0.55"
                                                                       Typography.Capitals="AllSmallCaps"/>
                                                            <TextBlock Text="~45%" FontSize="22" FontWeight="Bold"/>
                                                            <ProgressBar Value="45" Maximum="100"
                                                                         Height="4" Margin="0,4,0,0"
                                                                         Background="{DynamicResource MaterialDesignDivider}"
                                                                         Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                                         BorderThickness="0"/>
                                                        </StackPanel>
                                                        <StackPanel Margin="0,0,16,0">
                                                            <TextBlock Text="CLASSES"
                                                                       FontSize="10" FontWeight="Bold" Opacity="0.55"
                                                                       Typography.Capitals="AllSmallCaps"/>
                                                            <TextBlock Text="3" FontSize="22" FontWeight="Bold"/>
                                                            <TextBlock Text="Away · Draw · Home"
                                                                       FontSize="10" Opacity="0.6"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Text="LOOKBACK"
                                                                       FontSize="10" FontWeight="Bold" Opacity="0.55"
                                                                       Typography.Capitals="AllSmallCaps"/>
                                                            <TextBlock Text="5 games" FontSize="22" FontWeight="Bold"/>
                                                            <TextBlock Text="rolling window"
                                                                       FontSize="10" Opacity="0.6"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </UniformGrid>
                                                </StackPanel>
                                            </materialDesign:Card>

                                            <!-- EXPANDER: How it works (wrapped in rounded clip) -->
                                            <Border Margin="0,14,0,0"
                                                    CornerRadius="12"
                                                    Background="{DynamicResource MaterialDesignPaper}"
                                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                    BorderThickness="1"
                                                    ClipToBounds="True">
                                                <Border.Resources>
                                                    <Style TargetType="Expander" BasedOn="{StaticResource MaterialDesignExpander}">
                                                        <Setter Property="Background"      Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="materialDesign:ExpanderAssist.HorizontalHeaderPadding" Value="16,12"/>
                                                    </Style>
                                                </Border.Resources>
                                                <Expander>
                                                    <Expander.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon Kind="InformationOutline"
                                                                                     Width="16" Height="16"
                                                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                                     VerticalAlignment="Center"/>
                                                            <TextBlock Text="How predictions are made"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="8,0,0,0"/>
                                                        </StackPanel>
                                                    </Expander.Header>
                                                    <TextBlock Margin="16,4,16,16"
                                                               TextWrapping="Wrap"
                                                               FontSize="12" Opacity="0.75"
                                                               LineHeight="18"
                                                               Text="For each match, the engine aggregates the last 5 games of both teams into time-aware features (rolling means, goal-differential trends, head-to-head history). The OVA meta-learner runs three FastTree binary classifiers — Home-win, Draw, Away-win — and normalises their scores via softmax to produce calibrated probabilities shown on the main dashboard. Football outcomes are inherently difficult to predict: a micro-accuracy of ~44.6 % is competitive given that the naive 'always Home' baseline achieves ~45 %."/>
                                                </Expander>
                                            </Border>

                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>

                        </Border>

                        <!-- Empty State -->
                        <Border x:Name="EmptyState"
                                Grid.Row="1"
                                Grid.RowSpan="3"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                                MinHeight="{Binding ActualHeight,
                                           RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                Padding="32,24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Central content block -->
                                <StackPanel Grid.Row="0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">

                                    <!-- Icon in a round badge -->
                                    <Border Width="120" Height="120"
                                            CornerRadius="60"
                                            Background="{DynamicResource SecondaryHueMidBrush}"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,24">
                                        <materialDesign:PackIcon Kind="SoccerField"
                                                                 Width="60" Height="60"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                 Opacity="0.85"/>
                                    </Border>

                                    <TextBlock Text="Ready to predict"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Opacity="0.7"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="Select a season and both teams, then press Predict Match"
                                               FontSize="13"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Opacity="0.45"
                                               LineHeight="22"
                                               MaxWidth="320"
                                               Margin="0,0,0,24"/>

                                    <!-- Random Match button -->
                                    <Button x:Name="RandomBtn"
                                            Click="RandomBtn_Click"
                                            MouseEnter="RandomBtn_MouseEnter"
                                            Height="40"
                                            FontSize="13"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                            BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                            Cursor="Hand"
                                            HorizontalAlignment="Center"
                                            Width="220"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            Margin="0,0,0,40">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon x:Name="RandomIcon"
                                                                     Kind="DiceMultiple"
                                                                     Width="18" Height="18"
                                                                     VerticalAlignment="Center"
                                                                     Margin="0,0,8,0"/>
                                            <TextBlock Text="Surprise Me" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- How it works -->
                                    <Grid HorizontalAlignment="Center" MaxWidth="580">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Step 1 -->
                                        <Border Grid.Column="0"
                                                Padding="16,14"
                                                CornerRadius="10"
                                                Background="{DynamicResource MaterialDesignToolBarBackground}">
                                            <StackPanel HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Soccer"
                                                                         Width="24" Height="24"
                                                                         HorizontalAlignment="Center"
                                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                         Margin="0,0,0,8"/>
                                                <TextBlock Text="Select Match"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,0,4"/>
                                                <TextBlock Text="11 European leagues · 25,000+ matches"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           Opacity="0.55"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Step 2 -->
                                        <Border Grid.Column="2"
                                                Padding="16,14"
                                                CornerRadius="10"
                                                Background="{DynamicResource MaterialDesignToolBarBackground}">
                                            <StackPanel HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Brain"
                                                                         Width="24" Height="24"
                                                                         HorizontalAlignment="Center"
                                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                         Margin="0,0,0,8"/>
                                                <TextBlock Text="Crunch Data"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,0,4"/>
                                                <TextBlock Text="14 dynamic features · last 5 games"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           Opacity="0.55"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Step 3 -->
                                        <Border Grid.Column="4"
                                                Padding="16,14"
                                                CornerRadius="10"
                                                Background="{DynamicResource MaterialDesignToolBarBackground}">
                                            <StackPanel HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="ChartBar"
                                                                         Width="24" Height="24"
                                                                         HorizontalAlignment="Center"
                                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                         Margin="0,0,0,8"/>
                                                <TextBlock Text="Get Prediction"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,0,4"/>
                                                <TextBlock Text="FastTree OVA · Home / Draw / Away"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           Opacity="0.55"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                    </Grid>
                                </StackPanel>

                                <!-- Quick Stats panel at bottom -->
                                <Border Grid.Row="1"
                                        Padding="20,12"
                                        CornerRadius="10"
                                        Background="{DynamicResource MaterialDesignToolBarBackground}"
                                        Margin="0,16,0,0">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="DatabaseOutline"
                                                                 Width="16" Height="16"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                 Margin="0,0,8,0"/>
                                        <TextBlock x:Name="QuickStatsText"
                                                   FontSize="12"
                                                   Opacity="0.6"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </Border>

                    </Grid>
                </ScrollViewer>
            </materialDesign:Card>

        </Grid>

        <!-- ═══════════════════════════════════════════
             STATUS BAR
        ════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,1,0,0">
            <Grid Margin="22,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center"
                                             Opacity="0.45"
                                             Margin="0,0,7,0"/>
                    <TextBlock x:Name="StatusText"
                               FontSize="12" Opacity="0.6"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>