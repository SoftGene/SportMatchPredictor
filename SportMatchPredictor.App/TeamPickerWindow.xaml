<Window x:Class="SportMatchPredictor.App.TeamPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:SportMatchPredictor.App.Converters"
        Title="Select Team"
        Width="640" Height="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <converters:PathToImageSourceConverter x:Key="PathToImageSourceConverter"/>
        <Style x:Key="PickerSearchBox"
       TargetType="TextBox"
       BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="BorderBrush" Value="{DynamicResource AppOutlineBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="14"
        Background="{DynamicResource MaterialDesignBackground}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30"
                          ShadowDepth="8"
                          Opacity="0.3"
                          Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                Background="{DynamicResource PrimaryHueDarkBrush}"
                CornerRadius="14,14,0,0"
                Padding="24,14">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Soccer"
                                             Width="20" Height="20"
                                             Foreground="White"
                                             VerticalAlignment="Center"
                                             Margin="0,0,10,0"/>
                        <TextBlock x:Name="TitleText"
                               Text="Select Team"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Close button -->
                    <Button HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="CloseBtn_Click"
                        Width="32" Height="32"
                        Padding="0"
                        Background="#30FFFFFF"
                        BorderThickness="0"
                        materialDesign:ButtonAssist.CornerRadius="16"
                        materialDesign:ElevationAssist.Elevation="Dp0">
                        <materialDesign:PackIcon Kind="Close"
                                             Width="16" Height="16"
                                             Foreground="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Search box -->
            <Border Grid.Row="1"
        Padding="14,8"
        Background="{DynamicResource MaterialDesignBackground}"
        BorderBrush="{DynamicResource MaterialDesignDivider}"
        BorderThickness="0,0,0,1">
                <TextBox x:Name="SearchBox"
             materialDesign:HintAssist.Hint="Search team..."
             materialDesign:HintAssist.IsFloating="False"
             materialDesign:HintAssist.Foreground="{DynamicResource MaterialDesignBodyLight}"
             Style="{StaticResource PickerSearchBox}"
             Height="40"
             FontSize="13"
             VerticalContentAlignment="Center"
             Padding="10,0,10,0"
             BorderBrush="{DynamicResource AppOutlineBrush}"
             TextChanged="SearchBox_TextChanged"/>
            </Border>

            <!-- Teams grid -->
            <ScrollViewer Grid.Row="2"
              VerticalScrollBarVisibility="Auto"
              Margin="0"
              Padding="6,4,2,6">
                <ListBox x:Name="TeamsList"
         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
         VirtualizingPanel.IsVirtualizing="True"
         VirtualizingPanel.VirtualizationMode="Recycling"
         VirtualizingPanel.ScrollUnit="Pixel"
         BorderThickness="0"
         Background="Transparent"
         Padding="6,4,2,6">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,3,0,3"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Click="TeamCard_Click"
                    Tag="{Binding}"
                    Height="56"
                    HorizontalAlignment="Stretch"
                    Margin="0"
                    Padding="12,0"
                    Background="{DynamicResource MaterialDesignPaper}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    materialDesign:ButtonAssist.CornerRadius="10"
                    materialDesign:ElevationAssist.Elevation="Dp0"
                    Cursor="Hand">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Grid Width="36" Height="36" Margin="0,0,12,0">
                                        <Border CornerRadius="18"
                                Background="{DynamicResource SecondaryHueMidBrush}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LogoPath}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Initial}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryHueDarkBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <Image RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Source"
                                            Value="{Binding LogoPath, Converter={StaticResource PathToImageSourceConverter}}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LogoPath}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Grid>
                                    <TextBlock Text="{Binding TeamLongName}"
                               FontSize="13"
                               FontWeight="Medium"
                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

        </Grid>
    </Border>
</Window>